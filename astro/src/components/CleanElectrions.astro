---
import siteText from '../data/site-text.json';

const globalText = siteText.global;
const links = globalText.links;
const cleanText = globalText.cleanElections;

const modalTitle = cleanText.modalTitle ?? 'Donate to help us win.';
const modalBody =
	cleanText.modalBody ??
	"Help us reach our goal! Donate a maximum of $220 to support Eric's Clean Elections campaign.";
const progressLinkLabel = cleanText.progressLinkLabel ?? 'Track progress toward $5,293';
const donateNowLabel = cleanText.donateNowLabel ?? 'Donate Now';
---

<div id="cleanElectionsModal" class="clean-elections-modal" aria-hidden="true">
	<div class="modal-content-clean" role="dialog" aria-modal="true" aria-labelledby="clean-elections-title">
		<button class="close-clean-modal" aria-label="Close clean elections modal">&times;</button>
		<h2 id="clean-elections-title">{modalTitle}</h2>
		<p>{modalBody}</p>

		<a href={links.cleanElectionsProgressLink} class="progress-link" target="_blank" rel="noopener">
			{progressLinkLabel}
		</a>

		<a href={links.cleanElectionsDonateNow} class="donate-btn-modal" target="_blank" rel="noopener">
			{donateNowLabel}
		</a>
	</div>
</div>

<button id="cleanElectionsWidget" class="clean-elections-widget" aria-label="Open Clean Elections popup" type="button">
	<div class="widget-content">
		<div class="widget-icon">
			<i class="fas fa-hand-holding-dollar"></i>
		</div>
	</div>
</button>

<style>
.clean-elections-modal {
	display: none;
	position: fixed;
	z-index: 2000;
	left: 0;
	top: 0;
	width: 100%;
	height: 100%;
	background-color: rgba(0, 0, 0, 0.7);
	animation: fadeIn 0.3s ease;
}

.clean-elections-modal.active {
	display: flex;
	align-items: center;
	justify-content: center;
}

.modal-content-clean {
	background: var(--off-white);
	padding: 50px;
	border-radius: 8px;
	max-width: 600px;
	width: 90%;
	position: relative;
	box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
	animation: slideUp 0.4s ease;
}

@keyframes fadeIn {
	from {
		opacity: 0;
	}
	to {
		opacity: 1;
	}
}

@keyframes slideUp {
	from {
		transform: translateY(50px);
		opacity: 0;
	}
	to {
		transform: translateY(0);
		opacity: 1;
	}
}

.close-clean-modal {
	position: absolute;
	top: 20px;
	right: 25px;
	color: var(--main-blue);
	font-size: 32px;
	font-weight: bold;
	cursor: pointer;
	transition: color 0.3s;
	line-height: 1;
	border: none;
	background: transparent;
}

.close-clean-modal:hover {
	color: var(--bg-orange);
}

.modal-content-clean h2 {
	font-size: 36px;
	font-weight: 800;
	color: var(--main-blue);
	text-transform: uppercase;
	letter-spacing: -0.5px;
	margin-bottom: 20px;
	line-height: 1.1;
}

.modal-content-clean p {
	font-size: 18px;
	color: var(--main-blue);
	line-height: 1.6;
	margin-bottom: 8px;
	opacity: 0.9;
}

.progress-link {
	display: inline-block;
	margin-top: 12px;
	color: var(--main-blue);
	text-decoration: underline;
	font-weight: 700;
}

.donate-btn-modal {
	width: 100%;
	padding: 18px 40px;
	font-size: 22px;
	font-weight: 800;
	border: 4px solid var(--bg-orange);
	background: var(--bg-orange);
	color: var(--off-white);
	cursor: pointer;
	transition: all 0.3s;
	text-decoration: none;
	display: inline-block;
	text-align: center;
	letter-spacing: 1px;
	margin-top: 20px;
}

.donate-btn-modal:hover {
	background: transparent;
	color: var(--bg-orange);
	transform: translateY(-2px);
	box-shadow: 0 10px 25px rgba(254, 166, 85, 0.3);
}

.clean-elections-widget {
	display: none;
	position: fixed;
	bottom: 20px;
	right: 20px;
	background: rgba(23, 60, 98, 0.92);
	backdrop-filter: blur(10px);
	-webkit-backdrop-filter: blur(10px);
	border: 1px solid rgba(255, 255, 255, 0.12);
	color: var(--off-white);
	padding: 0;
	border-radius: 50%;
	width: 60px;
	height: 60px;
	box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
	cursor: pointer;
	z-index: 1999;
	transition: all 0.3s ease;
	animation: slideInRight 0.5s ease;
}

@keyframes slideInRight {
	from {
		transform: translateX(400px);
		opacity: 0;
	}
	to {
		transform: translateX(0);
		opacity: 1;
	}
}

.clean-elections-widget:hover {
	transform: translateY(-5px);
	background: rgba(23, 60, 98, 0.98);
	box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
}

.widget-content {
	display: flex;
	align-items: center;
	justify-content: center;
	width: 100%;
	height: 100%;
}

.widget-icon {
	font-size: 24px;
	color: var(--bg-orange);
}

@media (max-width: 1024px) {
	.clean-elections-widget {
		bottom: 15px;
		right: 15px;
	}

	.modal-content-clean {
		padding: 30px 25px;
		width: 95%;
	}

	.modal-content-clean h2 {
		font-size: 28px;
		margin-bottom: 15px;
	}

	.modal-content-clean p {
		font-size: 16px;
	}

	.donate-btn-modal {
		padding: 15px 30px;
		font-size: 18px;
	}

	.close-clean-modal {
		top: 15px;
		right: 15px;
		font-size: 28px;
	}
}

@media (max-width: 480px) {
	.clean-elections-widget {
		width: 50px;
		height: 50px;
		bottom: 12px;
		right: 12px;
	}

	.widget-icon {
		font-size: 20px;
	}

	.modal-content-clean {
		padding: 25px 20px;
	}

	.modal-content-clean h2 {
		font-size: 24px;
	}

	.modal-content-clean p {
		font-size: 15px;
	}

	.donate-btn-modal {
		padding: 12px 25px;
		font-size: 16px;
		border-width: 3px;
	}
}
</style>

<script>
	function closeCleanElectionsModal() {
		const modal = document.getElementById('cleanElectionsModal');
		const widget = document.getElementById('cleanElectionsWidget');

		if (modal && widget) {
			modal.classList.remove('active');
			widget.style.display = 'flex';
			localStorage.setItem('cleanElectionsModalShown', 'true');
		}
	}
	window.closeCleanElectionsModal = closeCleanElectionsModal;

	function initializeCleanElections() {
		const modal = document.getElementById('cleanElectionsModal');
		const widget = document.getElementById('cleanElectionsWidget');
		const closeModalButton = modal?.querySelector('.close-clean-modal');

		if (!modal || !widget) return;

		const openCleanElectionsModal = () => {
			modal.classList.add('active');
			widget.style.display = 'none';
		};

		if (!widget.dataset.listenersAttached) {
			widget.addEventListener('click', openCleanElectionsModal);

			if (closeModalButton) {
				closeModalButton.addEventListener('click', closeCleanElectionsModal);
			}

			window.addEventListener('click', (event) => {
				if (event.target === modal) closeCleanElectionsModal();
			});

			widget.dataset.listenersAttached = 'true';
		}

		widget.style.display = 'flex';
		modal.classList.remove('active');

		const hasSeenModal = localStorage.getItem('cleanElectionsModalShown');
		if (!hasSeenModal) {
			clearTimeout(window._cleanElectionsTimeout);
			window._cleanElectionsTimeout = setTimeout(openCleanElectionsModal, 1500);
		}
	}

	initializeCleanElections();
	document.addEventListener('astro:page-load', initializeCleanElections);
</script>
