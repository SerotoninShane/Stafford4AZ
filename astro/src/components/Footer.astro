---
// This is the "frontmatter" section. 
// You can add JavaScript/TypeScript here later if needed.
import siteText from '../data/site-text.json';

const globalText = siteText.global;
const links = globalText.links;
const social = globalText.social;
const footerText = globalText.footer;
---

<!-- Footer -->
<footer id="donate">
    <img src="/assets/icon.svg" alt="Eric Stafford for Arizona Senate" width="200" height="200" style="max-width:200px;height:auto;">
    <h3>{footerText.heading}</h3>
    <div class="footer-buttons">
        <a href={links.donate} class="btn-footer" target="_blank" rel="noopener" aria-label="Donate via ActBlue">{footerText.donateLabel}</a>
        <a href={links.getInvolved} class="btn-footer" aria-label="Get involved with the campaign">{footerText.getInvolvedLabel}</a>
    </div>

    <nav class="footer-links-row" aria-label="Footer navigation">
        <a href={links.endorsements}>{footerText.endorsementsLabel}</a>
        <span class="footer-sep">|</span>
        <a href={links.voterResources}>{footerText.voterResourcesLabel}</a>
        <span class="footer-sep">|</span>
        <a href={links.transparency}>{footerText.transparencyLabel}</a>
        <span class="footer-sep">|</span>
        <a href={links.contact}>{footerText.contactLabel}</a>
    </nav>
    <div class="footer-links-row footer-legal-row">
        <a href={links.privacy}>{footerText.privacyLabel}</a>
        <span class="footer-sep">|</span>
        <a href={links.terms}>{footerText.termsLabel}</a>
    </div>
    
    <div class="footer-legal-block">
        <p class="paid-for">{footerText.paidFor}</p>
    </div>

    <div class="footer-social">
    <a href={social.bluesky} aria-label="Bluesky" target="_blank" rel="noopener">
        <i class="fab fa-bluesky"></i>
    </a>
    <a href={social.instagram} aria-label="Instagram" target="_blank" rel="noopener">
        <i class="fab fa-instagram"></i>
    </a>
    <a href={social.youtube} aria-label="YouTube" target="_blank" rel="noopener">
        <i class="fab fa-youtube"></i>
    </a>
    <a href={social.x} aria-label="X (Twitter)" target="_blank" rel="noopener">
        <i class="fab fa-x-twitter"></i>
    </a>
    <a href={social.facebook} aria-label="Facebook" target="_blank" rel="noopener">
        <i class="fab fa-facebook"></i>
    </a>
    </div>

    <p class="copyright">{footerText.copyright}</p>
</footer>

<style>
/* Footer */
footer {
    background: var(--main-blue);
    color: var(--off-white);
    padding: 4vh;
    text-align: center;
    position: relative;
}

footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter><rect width="100" height="100" filter="url(%23noise)" opacity="0.15"/></svg>');
    opacity: 0.4;
    z-index: 1;
}

footer > * {
    position: relative;
    z-index: 2;
}

footer h3 {
    font-size: 42px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.footer-buttons {
    display: flex;
    gap: 25px;
    justify-content: center;
    margin: 2vh;
}

.btn-footer {
    padding: 1vh 4vh;
    font-size: 20px;
    font-weight: 800;
    border: 4px solid var(--bg-orange);
    background: transparent;
    color: var(--bg-orange);
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
    letter-spacing: 1px;
}

.btn-footer:hover {
    background: var(--bg-orange);
    color: var(--main-blue);
}

/* Footer Links Row */
.footer-links-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin: 2vh auto 0.5vh;
}

.footer-links-row a {
    color: var(--off-white);
    text-decoration: none;
    font-size: 14px;
    opacity: 0.8;
    transition: opacity 0.3s;
}

.footer-links-row a:hover {
    opacity: 1;
    text-decoration: underline;
}

.footer-sep {
    color: var(--off-white);
    opacity: 0.35;
    font-size: 13px;
    user-select: none;
}

.footer-legal-row {
    margin-top: 0;
    margin-bottom: 1.5vh;
}

.footer-legal-row a {
    font-size: 13px;
    opacity: 0.6;
}

.footer-social {
    display: flex;
    gap: 20px;
    justify-content: center;
    margin: 10px;
}

.footer-social a {
    color: var(--off-white);
    font-size: 24px;
}

.paid-for {
    border: 3px white solid;
    font-weight: bold;
    padding-block: 16px;
    padding-inline: 8px;
    margin: 2vh;
    width: fit-content;
    margin-inline: auto;
}

@media (max-width: 768px) {
    footer {
        /* Increase padding slightly on top/bottom for better visual separation */
        padding: 6vh 20px;
    }

    footer h3 {
        /* Decrease font size for mobile header */
        font-size: 32px;
    }

    .footer-buttons {
        /* Change to column layout to stack buttons vertically */
        flex-direction: column;
        gap: 15px;
        margin: 3vh auto;
        /* Constrain button group width */
        max-width: 300px;
    }

    .btn-footer {
        /* Adjust padding and font size for better mobile tap target */
        padding: 15px 3vh; /* Increased vertical padding */
        font-size: 18px;
        width: 100%; /* Make buttons full width of the container (max-width: 300px) */
    }

    .footer-legal-block p {
        /* Adjust font size for legal text */
        font-size: 14px;
    }

    .paid-for {
        /* Ensure paid-for text is legible */
        font-size: 19px;
    }

    .footer-social {
        /* Keep the same icon size or slightly decrease if needed */
        gap: 15px;
        margin-top: 15px;
    }
    
    .footer-social a {
        font-size: 22px;
    }

    .copyright {
        font-size: 12px;
        margin-top: 15px;
    }
}

/* Additional adjustment for very small screens (e.g., iPhone 5/SE) */
@media (max-width: 480px) {
    footer h3 {
        font-size: 28px;
    }
    
    .footer-buttons {
        max-width: 250px;
    }
}
</style>