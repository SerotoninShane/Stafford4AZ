---
// This is the "frontmatter" section.
// You can add JavaScript/TypeScript here later if needed.
import siteText from '../data/site-text.json';

const globalText = siteText.global;
const links = globalText.links;
const headerText = globalText.header;
---
<div class="top-banner">
    <span class="top-banner-spacer" aria-hidden="true">Meet Eric Stafford Near You →</span>
    <a href={links.es} class="top-banner-es">{headerText.spanishLabel}</a>
</div>
<header>
    <div class="header-left">
    <div class="logo">
        <a href={links.home}>
            <img src="/assets/logo.webp" alt="Eric Stafford Logo" width="200" height="60" style="max-width:100%;height:auto;">
        </a>
    </div>
        <div class="headshot"></div>
    </div>

        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
    </button>

    <nav id="nav-menu" aria-label="Main navigation">
        <div class="nav-left">
            <a href={links.home} data-astro-prefetch="viewport">{headerText.homeLabel}</a>
            <a href={links.about} data-astro-prefetch="viewport">{headerText.aboutLabel}</a>
            <a href={links.platform} data-astro-prefetch="viewport">{headerText.platformLabel}</a>
        </div>
        <div class="nav-right">
            <a href={links.donate} class="nav-btn" target="_blank">{headerText.donateLabel}</a>
            <a href={links.getInvolved} class="nav-btn">{headerText.getInvolvedLabel}</a>
        </div>
    </nav>
</header>

<style>
/* Top Banner */
.top-banner {
    background-color: var(--bg-orange);
    text-align: center;
    padding: 13px 20px;
    font-size: 16px;
    font-weight: 700;
    position: relative;
}
.top-banner a {
    color: var(--off-white);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
}
.top-banner-spacer {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    visibility: hidden;
    font-size: 16px;
    line-height: 1.2;
}
.top-banner-es {
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 13px;
    font-weight: 600;
    opacity: 0.85;
    border: 1px solid rgba(255,255,255,0.5);
    border-radius: 4px;
    padding: 3px 10px;
}
.top-banner-es:hover {
    opacity: 1;
    background: rgba(255,255,255,0.15);
}
/* Navigation */
header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 2vw;
    position: static;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
}
.logo {
    font-weight: 700;
    position: absolute;
    z-index: 100;
    top: -2px
}
.logo img {
    width: 420px;
    height: auto;
    aspect-ratio: 5 / 2;
    display: block;
}
.header-left {
    display: flex;
    align-items: center;
}
nav {
    display: flex;
    gap: 1vw;
    align-items: center;
    justify-content: center;
}
.nav-left {
    display: flex;
    gap: 1vw;
}
.nav-right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1vw;
    align-items: center;
    justify-content: center;
    text-align: center;
}
nav a {
    text-decoration: none;
    color: var(--main-blue);
    font-weight: 600;
    font-size: clamp(14px, 1.4vw, 20px);
    transition: opacity 0.3s;
    letter-spacing: 0.3px;
    display: flex;
    align-items: center;
}
nav .nav-btn {
    padding: 1vh 1.6vh;
    font-size: clamp(14px, 1.4vw, 20px);
    font-weight: 800;
    border: 3px solid var(--main-blue);
    background: transparent;
    color: var(--main-blue);
    cursor: pointer;
    transition: all 0.3s;
    text-decoration: none;
    display: inline-block;
    letter-spacing: 0.5px;
}
nav .nav-btn:hover {
    background: var(--main-blue);
    color: var(--off-white);
}

/* Hamburger Menu - Hidden by default */
.hamburger {
    display: none;
    flex-direction: column;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    z-index: 101;
}

.hamburger span {
    width: 30px;
    height: 3px;
    background-color: var(--main-blue);
    margin: 4px 0;
    transition: all 0.3s ease;
    border-radius: 3px;
}

.hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(8px, 8px);
}

.hamburger.active span:nth-child(2) {
    opacity: 0;
}

.hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(8px, -8px);
}

/* Lock body scroll when menu is open */
body.menu-open {
    overflow: hidden;
}

/* Mobile Navigation Styles */
@media (max-width: 1024px) {
    header {
        position: relative;
        justify-content: space-between; /* CHANGED: Space between logo and hamburger */
        align-items: center; /* ADDED: Vertical alignment */
        padding: 15px 20px;
    }

    .header-left {
        position: static;
        display: block;
        flex: 1; /* ADDED: Takes available space */
    }

    .logo {
        position: absolute;
        top: -38px;
        left: 0;
        transform: none;
        text-align: left; /* CHANGED: Left align instead of center */
        width: auto; /* CHANGED: Auto width instead of 100% */
        z-index: 10;
    }

    .logo img {
        width: 420px; /* INCREASED: Larger logo size */
        margin: 0; /* CHANGED: Remove auto margin for left alignment */
    }
    
    .hamburger {
        display: flex;
        position: relative; /* CHANGED: From absolute to relative */
        right: auto; /* REMOVED: Absolute positioning */
        top: auto; /* REMOVED: Absolute positioning */
        transform: none; /* REMOVED: Transform */
        flex-shrink: 0; /* ADDED: Prevent hamburger from shrinking */
    }

    .top-banner {
        display: flex;
        flex-direction: column;
        align-items: center;
        font-size: 12px;
        padding: 8px 10px;
        gap: 4px;
    }
    .top-banner-es {
        position: static;
        transform: none;
        font-size: 11px;
        padding: 2px 8px;
    }

    nav {
        position: fixed;
        top: 0;
        right: -100vw;
        width: 100vw;
        height: 100vh;
        background-color: var(--off-white);
        flex-direction: column;
        padding: 120px 30px 30px;
        gap: 0;
        box-shadow: none;
        transition: right 0.3s ease;
        overflow-y: auto;
        z-index: 100;
    }

    nav.active {
        right: 0;
    }
    
    .nav-left {
        flex-direction: column;
        gap: 0;
        width: 100%;
        margin-bottom: 30px;
    }

    .nav-left a {
        padding: 15px 0;
        border-bottom: 1px solid rgba(23, 60, 98, 0.1);
        width: 100%;
        font-size: 18px;
    }

    .nav-right {
        display: flex;
        flex-direction: column;
        gap: 15px;
        width: 100%;
    }

    nav .nav-btn {
        width: 100%;
        padding: 15px;
        font-size: 18px;
        text-align: center;
        justify-content: center;
    }
}

@media (max-width: 480px) {
        header {
        position: relative;
        justify-content: space-between; /* CHANGED: Space between logo and hamburger */
        align-items: center; /* ADDED: Vertical alignment */
    padding: 12px 16px;
    }
        .logo {
        position: absolute;
    top: -24px;
        left: 0;
        transform: none;
        text-align: left; /* CHANGED: Left align instead of center */
        width: auto; /* CHANGED: Auto width instead of 100% */
        z-index: 10;
    }
    .logo img {
        width: 300px; /* ADJUSTED: Slightly smaller on very small screens but still bigger than before */
    }

    nav {
        width: 100vw;
        right: -100vw;
    }

    .hamburger span {
        width: 25px;
    }
}
</style>

<script>
    function setupMobileMenu() {
        const hamburger = document.getElementById('hamburger');
        const navMenu = document.getElementById('nav-menu');
        const body = document.body;
        let scrollY = 0;

        if (!hamburger || !navMenu) {
            return;
        }

        function toggleMenu() {
            const isOpening = !hamburger.classList.contains('active');
            
            if (isOpening) {
                scrollY = window.scrollY;
                body.style.top = `-${scrollY}px`;
                body.style.position = 'fixed';
                body.style.width = '100%';
            } else {
                body.style.position = '';
                body.style.top = '';
                body.style.width = '';
                window.scrollTo(0, scrollY);
            }
            
            hamburger.classList.toggle('active');
            navMenu.classList.toggle('active');
            body.classList.toggle('menu-open');
        }

        if (!hamburger.dataset.listenersAttached) {
            hamburger.addEventListener('click', toggleMenu);
            hamburger.dataset.listenersAttached = 'true';

            const navLinks = navMenu.querySelectorAll('a');
            navLinks.forEach(link => {
                link.addEventListener('click', (e) => {
                    if (navMenu.classList.contains('active')) {
                        e.preventDefault();
                        const href = link.getAttribute('href');
                        
                        toggleMenu();
                        
                        setTimeout(() => {
                            window.location.href = href;
                        }, 200);
                    }
                });
            });
        }
        
        hamburger.classList.remove('active');
        navMenu.classList.remove('active');
        body.classList.remove('menu-open');
    }

    setupMobileMenu();
    document.addEventListener('astro:page-load', setupMobileMenu);
</script>