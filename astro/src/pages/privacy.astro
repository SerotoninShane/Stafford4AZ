---
// Import the layout
import BaseLayout from '../layouts/BaseLayout.astro';
import siteText from '../data/site-text.json';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford for Arizona Senate - Privacy Policy";
const pageUrl = '/privacy';
const pageDescription = "Read the Privacy Policy for Eric Stafford's campaign for Arizona Senate, including how we collect and use personal data for LD29 communications";
const links = siteText.global.links;
const privacyText = siteText.privacy;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="mini-hero">
    <div class="mini-hero-content">
        <h2>{privacyText.heroTitle}</h2>
    </div>
</section>

<section class="privacy-content">
  <div class="legal-header">
            <h2>{privacyText.headerTitle}</h2>
            <p class="legal-meta">{privacyText.meta}</p>
  </div>

    {privacyText.sections.map((section, index) => (
        <div class="legal-section">
            <h3><span class="section-num">{index + 1}</span> {section.title}</h3>
            {index === privacyText.sections.length - 1 ? (
                <p>{section.body.replace('contact us', '')}<a href={links.contact}>contact us</a>.</p>
            ) : (
                <p>{section.body}</p>
            )}
            {section.list && (
                <ul>
                    {section.list.map((item) => (
                        <li>{item}</li>
                    ))}
                </ul>
            )}
            {index === privacyText.sections.length - 1 && (
                <div class="legal-contact-box">
                    {privacyText.contactBox}
                </div>
            )}
        </div>
    ))}

    <p class="legal-closing">{privacyText.closing}</p>
</section>

</BaseLayout>

<style>
.privacy-content {
    max-width: 780px;
    margin: 0 auto;
    padding: 50px 40px 70px;
}

.legal-header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 2px solid rgba(23, 60, 98, 0.1);
}

.legal-header h2 {
    font-size: 32px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    margin-bottom: 8px;
}

.legal-meta {
    font-size: 14px;
    color: var(--main-blue);
    opacity: 0.55;
}

.legal-section {
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(23, 60, 98, 0.06);
}

.legal-section:last-of-type {
    border-bottom: none;
}

.legal-section h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--main-blue);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.section-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(254, 166, 85, 0.15);
    color: var(--bg-orange);
    font-size: 13px;
    font-weight: 800;
    flex-shrink: 0;
}

.legal-section p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--main-blue);
    opacity: 0.85;
}

.legal-section ul {
    margin: 12px 0 0 0;
    padding-left: 20px;
}

.legal-section li {
    font-size: 15px;
    line-height: 1.75;
    color: var(--main-blue);
    opacity: 0.85;
    margin-bottom: 4px;
}

.legal-section a {
    color: var(--bg-orange);
    text-decoration: underline;
}

.legal-contact-box {
    margin-top: 12px;
    padding: 14px 18px;
    background: rgba(23, 60, 98, 0.04);
    border-left: 3px solid var(--main-blue);
    border-radius: 0 6px 6px 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--main-blue);
}

.legal-closing {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 2px solid rgba(23, 60, 98, 0.1);
    font-size: 15px;
    line-height: 1.7;
    color: var(--main-blue);
    opacity: 0.7;
    font-style: italic;
}

@media (max-width: 768px) {
    .privacy-content {
        padding: 30px 20px 50px;
    }

    .legal-header h2 {
        font-size: 26px;
    }
}
</style>