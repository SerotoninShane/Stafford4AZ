---
// Import the layout
import BaseLayout from '../layouts/BaseLayout.astro';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford for Arizona Senate - Privacy Policy";
const pageUrl = '/privacy';
const pageDescription = "Read the Privacy Policy for Eric Stafford's campaign for Arizona Senate, including how we collect and use personal data for LD29 communications";
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="mini-hero">
    <div class="mini-hero-content">
        <h2>Privacy Policy</h2>
    </div>
</section>

<section class="privacy-content">
  <div class="legal-header">
      <h2>Privacy Policy</h2>
      <p class="legal-meta">Effective Date: January 1, 2025 &nbsp;·&nbsp; Last Updated: January 1, 2025</p>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">1</span> Introduction</h3>
      <p>Eric Stafford for Arizona Senate ("Campaign," "we," "us," or "our") respects your privacy and is committed to protecting your personal information. This Privacy Policy explains how we collect, use, and safeguard information provided by supporters, volunteers, and website visitors in LD29 and across Arizona.</p>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">2</span> Information We Collect</h3>
      <p>When you interact with our website or campaign, we may collect the following information:</p>
      <ul>
        <li>Name</li>
        <li>Email address</li>
        <li>Phone number</li>
        <li>ZIP code</li>
        <li>Other information you provide voluntarily (e.g., donations or volunteer sign-ups)</li>
      </ul>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">3</span> How We Use Your Information</h3>
      <p>We use your information for campaign purposes only, including:</p>
      <ul>
        <li>Sending updates, event invitations, and volunteer opportunities</li>
        <li>Requesting donations and providing campaign information</li>
        <li>Sending voting reminders and election information</li>
        <li>Improving our website and campaign outreach</li>
      </ul>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">4</span> Text Messaging &amp; Email Communications</h3>
      <p>By providing your phone number or email, you consent to receive communications from the campaign. You may receive up to 1 text message per day. Standard message and data rates may apply. You can opt out of text messages by texting <strong>STOP</strong> or opt out of emails by clicking "unsubscribe" in any message.</p>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">5</span> Sharing of Information</h3>
      <p>We do not sell or rent your personal information to third parties. Information may be shared with trusted service providers who assist with campaign operations, in accordance with applicable federal and state election laws.</p>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">6</span> Security</h3>
      <p>We take reasonable measures to protect the personal information we collect. However, no method of transmission over the Internet or electronic storage is completely secure, and we cannot guarantee absolute security.</p>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">7</span> Your Rights</h3>
      <p>You may request access to, correction, or deletion of your personal information by contacting us directly. You may also unsubscribe from campaign emails or texts at any time as described above.</p>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">8</span> Third-Party Links</h3>
      <p>Our website may contain links to third-party sites. We are not responsible for the privacy practices or content of these external websites.</p>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">9</span> Changes to this Policy</h3>
      <p>We may update this Privacy Policy from time to time. Changes will be posted with an updated "Last Updated" date. Continued use of the website constitutes acceptance of the revised policy.</p>
  </div>

  <div class="legal-section">
      <h3><span class="section-num">10</span> Contact Information</h3>
      <p>If you have any questions about this Privacy Policy, please <a href="/contact">contact us</a>.</p>
      <div class="legal-contact-box">
          Eric Stafford for Arizona Senate
      </div>
  </div>

  <p class="legal-closing">Thank you for supporting Eric Stafford's campaign for Arizona Senate. We respect your privacy and are committed to protecting your personal information as we work to put LD29 families first.</p>
</section>

</BaseLayout>

<style>
.privacy-content {
    max-width: 780px;
    margin: 0 auto;
    padding: 50px 40px 70px;
}

.legal-header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 2px solid rgba(23, 60, 98, 0.1);
}

.legal-header h2 {
    font-size: 32px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    margin-bottom: 8px;
}

.legal-meta {
    font-size: 14px;
    color: var(--main-blue);
    opacity: 0.55;
}

.legal-section {
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(23, 60, 98, 0.06);
}

.legal-section:last-of-type {
    border-bottom: none;
}

.legal-section h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--main-blue);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.section-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(254, 166, 85, 0.15);
    color: var(--bg-orange);
    font-size: 13px;
    font-weight: 800;
    flex-shrink: 0;
}

.legal-section p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--main-blue);
    opacity: 0.85;
}

.legal-section ul {
    margin: 12px 0 0 0;
    padding-left: 20px;
}

.legal-section li {
    font-size: 15px;
    line-height: 1.75;
    color: var(--main-blue);
    opacity: 0.85;
    margin-bottom: 4px;
}

.legal-section a {
    color: var(--bg-orange);
    text-decoration: underline;
}

.legal-contact-box {
    margin-top: 12px;
    padding: 14px 18px;
    background: rgba(23, 60, 98, 0.04);
    border-left: 3px solid var(--main-blue);
    border-radius: 0 6px 6px 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--main-blue);
}

.legal-closing {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 2px solid rgba(23, 60, 98, 0.1);
    font-size: 15px;
    line-height: 1.7;
    color: var(--main-blue);
    opacity: 0.7;
    font-style: italic;
}

@media (max-width: 768px) {
    .privacy-content {
        padding: 30px 20px 50px;
    }

    .legal-header h2 {
        font-size: 26px;
    }
}
</style>