---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteText from '../data/site-text.json';
const pageTitle = "Eric Stafford for Arizona Senate - Voter Resources";
const pageUrl = '/voter-resources';
const pageDescription = "Find voter registration info, check if you're in LD29, locate your polling place, and learn about early voting in Arizona.";
const links = siteText.global.links;
const voterText = siteText.voterResources;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="mini-hero">
    <div class="mini-hero-content">
        <h2>{voterText.heroTitle}</h2>
    </div>
</section>

<section class="voter-resources-page reveal">
    <div class="voter-resources-header">
        <h2>{voterText.headerTitle}</h2>
        <p>{voterText.headerBody}</p>
    </div>

    <div class="voter-cards-grid">
        <!-- Am I in LD29? -->
        <div class="voter-card">
            <div class="voter-card-icon">
                <i class="fas fa-map-location-dot"></i>
            </div>
            <h3>{voterText.cards.district.title}</h3>
            <p>{voterText.cards.district.body}</p>
            <a href={links.findMyDistrict} class="btn voter-card-btn" target="_blank" rel="noopener">{voterText.findDistrictLabel}</a>
        </div>

        <!-- Register to Vote -->
        <div class="voter-card">
            <div class="voter-card-icon">
                <i class="fas fa-clipboard-check"></i>
            </div>
            <h3>{voterText.cards.register.title}</h3>
            <p>{voterText.cards.register.body}</p>
            <a href={links.registerToVote} class="btn voter-card-btn" target="_blank" rel="noopener">{voterText.registerLabel}</a>
        </div>

        <!-- Check Registration -->
        <div class="voter-card">
            <div class="voter-card-icon">
                <i class="fas fa-user-check"></i>
            </div>
            <h3>{voterText.cards.check.title}</h3>
            <p>{voterText.cards.check.body}</p>
            <a href={links.checkVoterStatus} class="btn voter-card-btn" target="_blank" rel="noopener">{voterText.checkStatusLabel}</a>
        </div>

        <!-- Early Voting -->
        <div class="voter-card">
            <div class="voter-card-icon">
                <i class="fas fa-envelope-open-text"></i>
            </div>
            <h3>{voterText.cards.early.title}</h3>
            <p>{voterText.cards.early.body}</p>
            <a href={links.earlyVoting} class="btn voter-card-btn" target="_blank" rel="noopener">{voterText.earlyVotingLabel}</a>
        </div>

        <!-- Polling Locations -->
        <div class="voter-card">
            <div class="voter-card-icon">
                <i class="fas fa-location-dot"></i>
            </div>
            <h3>{voterText.cards.polling.title}</h3>
            <p>{voterText.cards.polling.body}</p>
            <a href={links.findVoteCenter} class="btn voter-card-btn" target="_blank" rel="noopener">{voterText.findVoteCenterLabel}</a>
        </div>

        <!-- Key Dates -->
        <div class="voter-card voter-card-highlight">
            <div class="voter-card-icon">
                <i class="fas fa-calendar-day"></i>
            </div>
            <h3>{voterText.cards.dates.title}</h3>
            <ul class="key-dates-list">
                {voterText.keyDates.map((item) => (
                    <li><strong>{item.date}</strong> — {item.label}</li>
                ))}
            </ul>
        </div>
    </div>

    <!-- LD29 Info -->
    <div class="ld29-info-section">
        <h3>{voterText.districtInfoTitle}</h3>
        <div class="ld29-stats">
            {voterText.districtStats.map((stat) => (
                <div class="ld29-stat">
                    <span class="stat-number">{stat.number}</span>
                    <span class="stat-label">{stat.label}</span>
                </div>
            ))}
        </div>
        <p>{voterText.districtBody}</p>
        <p class="ld29-zip-note">{voterText.zipNote}</p>
    </div>
</section>

</BaseLayout>

<style>
.voter-resources-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 60px 40px 80px;
}

.voter-resources-header {
    text-align: center;
    margin-bottom: 50px;
}

.voter-resources-header h2 {
    font-size: 36px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    margin-bottom: 16px;
}

.voter-resources-header p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--main-blue);
    opacity: 0.9;
    max-width: 700px;
    margin: 0 auto;
}

.voter-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 60px;
}

.voter-card {
    background: white;
    border-radius: 8px;
    padding: 30px 24px;
    border: 2px solid rgba(23, 60, 98, 0.08);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s, box-shadow 0.3s;
}

.voter-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
}

.voter-card-highlight {
    background: rgba(254, 166, 85, 0.08);
    border-color: var(--bg-orange);
}

.voter-card-icon {
    font-size: 28px;
    color: var(--bg-orange);
    margin-bottom: 16px;
}

.voter-card h3 {
    font-size: 20px;
    font-weight: 700;
    color: var(--main-blue);
    margin-bottom: 10px;
}

.voter-card p {
    font-size: 15px;
    color: var(--main-blue);
    opacity: 0.8;
    line-height: 1.6;
    flex: 1;
    margin-bottom: 20px;
}

.voter-card-btn {
    padding: 10px 20px;
    font-size: 14px;
    border-color: var(--main-blue);
    color: var(--main-blue);
    align-self: flex-start;
}

.voter-card-btn:hover {
    background: var(--main-blue);
    color: var(--off-white);
}

.key-dates-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.key-dates-list li {
    font-size: 15px;
    color: var(--main-blue);
    padding: 8px 0;
    border-bottom: 1px solid rgba(23, 60, 98, 0.1);
}

.key-dates-list li strong {
    color: var(--bg-orange);
    margin-right: 8px;
}

/* LD29 Info */
.ld29-info-section {
    padding: 40px;
    background: linear-gradient(135deg, var(--main-blue), #122940);
    border-radius: 8px;
    color: var(--off-white);
    text-align: center;
}

.ld29-info-section h3 {
    font-size: 28px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 24px;
}

.ld29-stats {
    display: flex;
    justify-content: center;
    gap: 60px;
    margin-bottom: 24px;
}

.ld29-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.stat-number {
    font-size: 32px;
    font-weight: 800;
    color: var(--bg-orange);
}

.stat-label {
    font-size: 14px;
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.ld29-info-section p {
    font-size: 16px;
    line-height: 1.7;
    opacity: 0.9;
    max-width: 650px;
    margin: 0 auto 12px;
}

.ld29-zip-note {
    font-size: 14px !important;
    opacity: 0.7 !important;
}

@media (max-width: 768px) {
    .voter-resources-page {
        padding: 40px 20px 60px;
    }

    .voter-resources-header h2 {
        font-size: 28px;
    }

    .voter-cards-grid {
        grid-template-columns: 1fr;
        gap: 16px;
    }

    .ld29-stats {
        flex-direction: column;
        gap: 20px;
    }

    .ld29-info-section {
        padding: 30px 20px;
    }
}
</style>
