---
// Import the layout
import BaseLayout from '../layouts/BaseLayout.astro';
import siteText from '../data/site-text.json';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford for Arizona Senate - About";
const pageUrl = '/about';
const pageDescription = "Meet Eric Stafford — community organizer, tradesman, and Clean Elections candidate running for Arizona State Senate in LD29.";
const links = siteText.global.links;
const aboutText = siteText.about;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="mini-hero">
    <div class="mini-hero-content">
        <h2>{aboutText.heroTitle}</h2>
    </div>
</section>

<!-- Bio Intro — Image + Intro side by side -->
<section class="about-intro reveal">
    <div class="about-intro-inner">
        <div class="about-intro-image">
            <img src="/assets/eric.webp" alt="Eric Stafford" width="340" height="450" loading="eager" style="max-width:100%;height:auto;" />
        </div>
        <div class="about-intro-text">
            <h2>{aboutText.introHeading}</h2>
            <p class="about-lead">{aboutText.introLead}</p>
            <div class="about-quick-facts">
                <div class="about-fact">
                    <i class="fas fa-wrench"></i>
                    <span>{aboutText.quickFacts[0]}</span>
                </div>
                <div class="about-fact">
                    <i class="fas fa-award"></i>
                    <span>{aboutText.quickFacts[1]}</span>
                </div>
                <div class="about-fact">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>{aboutText.quickFacts[2]}</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Full Bio -->
<section class="about-bio reveal">
    <div class="about-bio-inner">
        <p>{aboutText.bioParagraphs[0]}</p>

        <p>{aboutText.bioParagraphs[1]}</p>

        <p>{aboutText.bioParagraphs[2]}</p>

        <div class="about-priorities">
            <div class="about-priority">
                <i class="fas fa-graduation-cap"></i>
                <div>
                    <strong>{aboutText.priorities[0].title}</strong>
                    <span>{aboutText.priorities[0].description}</span>
                </div>
            </div>
            <div class="about-priority">
                <i class="fas fa-hard-hat"></i>
                <div>
                    <strong>{aboutText.priorities[1].title}</strong>
                    <span>{aboutText.priorities[1].description}</span>
                </div>
            </div>
            <div class="about-priority">
                <i class="fas fa-water"></i>
                <div>
                    <strong>{aboutText.priorities[2].title}</strong>
                    <span>{aboutText.priorities[2].description}</span>
                </div>
            </div>
        </div>

        <p>{aboutText.bioClosing}</p>

    <a href={links.platform} class="btn about-platform-btn">{aboutText.platformCta}</a>
    </div>
</section>

<!-- Why This Race Matters -->
<section class="about-race-matters reveal">
    <div class="about-race-matters-inner">
        <h2>{aboutText.raceTitle}</h2>
        <p class="race-matters-lead">{aboutText.raceLead}</p>
        <div class="race-matters-grid">
            <div class="race-matters-card">
                <div class="race-matters-number">{aboutText.raceStats[0].number}</div>
                <span>{aboutText.raceStats[0].label}</span>
            </div>
            <div class="race-matters-card">
                <div class="race-matters-number">{aboutText.raceStats[1].number}</div>
                <span>{aboutText.raceStats[1].label}</span>
            </div>
            <div class="race-matters-card">
                <div class="race-matters-number">{aboutText.raceStats[2].number}</div>
                <span>{aboutText.raceStats[2].label}</span>
            </div>
        </div>
        <p>{aboutText.raceParagraphs[0]}</p>
        <p>{aboutText.raceParagraphs[1]}</p>
        <div class="race-matters-cta">
            <a href={links.donate} class="btn race-matters-btn" target="_blank">{aboutText.donateCta}</a>
            <a href={links.getInvolved} class="btn race-matters-btn-secondary">{aboutText.volunteerCta}</a>
        </div>
    </div>
</section>

<!-- Transparency / Clean Candidate -->
<section class="about-transparency reveal">
    <div class="about-transparency-content">
        <div class="about-transparency-icon">
            <i class="fas fa-award"></i>
        </div>
        <h2>{aboutText.transparencyTitle}</h2>
        <p>{aboutText.transparencyBody}</p>
        <div class="about-transparency-highlights">
            <div class="about-transparency-item">
                <i class="fas fa-check-circle"></i>
                <span>{aboutText.transparencyItems[0]}</span>
            </div>
            <div class="about-transparency-item">
                <i class="fas fa-check-circle"></i>
                <span>{aboutText.transparencyItems[1]}</span>
            </div>
            <div class="about-transparency-item">
                <i class="fas fa-check-circle"></i>
                <span>{aboutText.transparencyItems[2]}</span>
            </div>
        </div>
        <a href={links.transparency} class="btn about-transparency-btn">{aboutText.transparencyCta}</a>
    </div>
</section>

</BaseLayout>

<style>
/* About Intro — Side by side */
.about-intro {
    padding: 60px 40px;
    background: var(--off-white);
}

.about-intro-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 48px;
    align-items: start;
}

.about-intro-image {
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
}

.about-intro-image img {
    width: 100%;
    height: auto;
    display: block;
    filter: saturate(170%) contrast(115%);
}

.about-intro-text h2 {
    font-size: 28px;
    font-weight: 800;
    color: var(--main-blue);
    text-transform: uppercase;
    margin-bottom: 16px;
    line-height: 1.3;
}

.about-lead {
    font-size: 17px;
    line-height: 1.7;
    color: var(--main-blue);
    margin-bottom: 24px;
}

.about-quick-facts {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.about-fact {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: var(--main-blue);
    font-weight: 600;
}

.about-fact i {
    color: var(--bg-orange);
    font-size: 18px;
    width: 24px;
    text-align: center;
}

/* Full Bio */
.about-bio {
    padding: 60px 40px;
    background: white;
}

.about-bio-inner {
    max-width: 750px;
    margin: 0 auto;
}

.about-bio-inner p {
    font-size: 17px;
    line-height: 1.8;
    color: var(--main-blue);
    margin-bottom: 24px;
}

.about-priorities {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 28px 0;
    padding: 24px;
    background: rgba(23, 60, 98, 0.03);
    border-radius: 8px;
    border-left: 4px solid var(--bg-orange);
}

.about-priority {
    display: flex;
    align-items: flex-start;
    gap: 14px;
}

.about-priority i {
    color: var(--bg-orange);
    font-size: 20px;
    margin-top: 4px;
    min-width: 24px;
    text-align: center;
}

.about-priority strong {
    display: block;
    font-size: 16px;
    color: var(--main-blue);
    margin-bottom: 2px;
}

.about-priority span {
    font-size: 15px;
    color: var(--main-blue);
    opacity: 0.8;
    line-height: 1.5;
}

.about-platform-btn {
    border-color: var(--main-blue);
    color: var(--main-blue);
    padding: 12px 28px;
    margin-top: 8px;
}

.about-platform-btn:hover {
    background: var(--main-blue);
    color: var(--off-white);
}

/* Why This Race Matters */
.about-race-matters {
    padding: 80px 40px;
    background: linear-gradient(135deg, var(--main-blue), #122940);
    color: var(--off-white);
    position: relative;
    overflow: hidden;
}

.about-race-matters::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/assets/background.webp');
    background-size: cover;
    background-position: center;
    filter: grayscale(100%) contrast(200%);
    opacity: 0.06;
    z-index: 1;
}

.about-race-matters-inner {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
}

.about-race-matters h2 {
    font-size: 36px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 16px;
}

.race-matters-lead {
    font-size: 19px;
    opacity: 0.9;
    line-height: 1.6;
    margin-bottom: 36px;
}

.race-matters-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 36px;
}

.race-matters-card {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    padding: 28px 16px;
}

.race-matters-number {
    font-size: 36px;
    font-weight: 800;
    color: var(--bg-orange);
    margin-bottom: 6px;
}

.race-matters-card span {
    font-size: 14px;
    opacity: 0.75;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.about-race-matters-inner > p {
    font-size: 16px;
    line-height: 1.7;
    opacity: 0.85;
    margin-bottom: 16px;
    text-align: left;
}

.race-matters-cta {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-top: 32px;
}

.race-matters-btn {
    background: var(--bg-orange);
    border-color: var(--bg-orange);
    color: var(--main-blue);
    padding: 14px 32px;
    font-weight: 700;
}

.race-matters-btn:hover {
    background: #e8943e;
    border-color: #e8943e;
}

.race-matters-btn-secondary {
    border-color: var(--off-white);
    color: var(--off-white);
    padding: 14px 32px;
}

.race-matters-btn-secondary:hover {
    background: var(--off-white);
    color: var(--main-blue);
}

/* Transparency */
.about-transparency {
    padding: 60px 40px;
    background: var(--off-white);
}

.about-transparency-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
}

.about-transparency-icon {
    font-size: 40px;
    color: var(--bg-orange);
    margin-bottom: 16px;
}

.about-transparency h2 {
    font-size: 30px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    margin-bottom: 16px;
}

.about-transparency p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--main-blue);
    opacity: 0.85;
    margin-bottom: 28px;
}

.about-transparency-highlights {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 28px;
}

.about-transparency-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: var(--main-blue);
}

.about-transparency-item i {
    color: var(--bg-orange);
    font-size: 16px;
}

.about-transparency-btn {
    border-color: var(--main-blue);
    color: var(--main-blue);
    padding: 12px 32px;
}

.about-transparency-btn:hover {
    background: var(--main-blue);
    color: var(--off-white);
}

/* Responsive */
@media (max-width: 768px) {
    .about-intro {
        padding: 40px 20px;
    }

    .about-intro-inner {
        grid-template-columns: 1fr;
        gap: 28px;
    }

    .about-intro-image {
        max-width: 280px;
        margin: 0 auto;
    }

    .about-intro-text {
        text-align: center;
    }

    .about-intro-text h2 {
        font-size: 22px;
    }

    .about-quick-facts {
        align-items: center;
    }

    .about-bio {
        padding: 40px 20px;
    }

    .about-priorities {
        padding: 20px;
    }

    .about-race-matters {
        padding: 50px 20px;
    }

    .about-race-matters h2 {
        font-size: 26px;
    }

    .race-matters-grid {
        grid-template-columns: 1fr;
        gap: 12px;
    }

    .race-matters-card {
        padding: 20px;
    }

    .race-matters-number {
        font-size: 28px;
    }

    .about-race-matters-inner > p {
        text-align: center;
    }

    .race-matters-cta {
        flex-direction: column;
    }

    .about-transparency {
        padding: 40px 20px;
    }

    .about-transparency h2 {
        font-size: 24px;
    }

    .about-transparency-highlights {
        flex-direction: column;
        align-items: center;
        gap: 12px;
    }
}
</style>