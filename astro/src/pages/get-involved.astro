---
// Import the layout
import BaseLayout from '../layouts/BaseLayout.astro';
import Schedule from '../components/Calendar.astro';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford for Arizona Senate - Get Involved";
const pageUrl = '/get-involved';
const pageDescription = "Find upcoming events, volunteer opportunities, and ways to support Eric Stafford's Arizona Senate campaign in LD29.";
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="mini-hero">
    <div class="mini-hero-content">
        <h2>Events & Get Involved</h2>
    </div>
</section>

<!-- Events Intro -->
<section class="events-intro reveal">
    <div class="events-intro-content">
        <h2>Join Us on the Trail</h2>
        <p>
            This campaign belongs to all of us. Whether you want to knock on doors, attend a town hall, or simply learn more about what we're fighting for — there's a place for you. Check the calendar below for upcoming events across LD29.
        </p>
    </div>
</section>

<!-- Calendar Section -->
<section class="events-calendar-section reveal">
    <Schedule />
</section>

<!-- Volunteer CTA Section -->
<section class="volunteer-section reveal">
    <div class="volunteer-content">
        <div class="volunteer-text">
            <h2>Volunteer With Us</h2>
            <p>We're building a grassroots movement across Surprise, the West Valley, and all of LD29. We need volunteers to help canvass, phone bank, host events, and spread the word.</p>
            <ul class="volunteer-ways">
                <li>
                    <i class="fas fa-door-open"></i>
                    <div>
                        <strong>Door Knocking</strong>
                        <span>Meet voters face to face in your neighborhood</span>
                    </div>
                </li>
                <li>
                    <i class="fas fa-phone"></i>
                    <div>
                        <strong>Phone Banking</strong>
                        <span>Make calls from home on your own schedule</span>
                    </div>
                </li>
                <li>
                    <i class="fas fa-signs-post"></i>
                    <div>
                        <strong>Yard Signs & Literature</strong>
                        <span>Show your support and help distribute materials</span>
                    </div>
                </li>
                <li>
                    <i class="fas fa-people-group"></i>
                    <div>
                        <strong>Host an Event</strong>
                        <span>Organize a meet-and-greet in your community</span>
                    </div>
                </li>
            </ul>
        </div>
        <div class="volunteer-form-wrapper">
            <h3>Sign Up to Volunteer</h3>
            <form class="volunteer-form" name="volunteer-signup" method="POST" data-netlify="true" action="/thank-you">
                <input type="hidden" name="form-name" value="volunteer-signup">
                <div class="form-group">
                    <label for="vol-name">Full Name</label>
                    <input type="text" id="vol-name" name="name" required>
                </div>
                <div class="form-group">
                    <label for="vol-email">Email</label>
                    <input type="email" id="vol-email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="vol-phone">Phone</label>
                    <input type="tel" id="vol-phone" name="phone">
                </div>
                <div class="form-group">
                    <label for="vol-zip">Zip Code</label>
                    <input type="text" id="vol-zip" name="zip" pattern="[0-9]{5}" title="Please enter a 5-digit zip code">
                </div>
                <div class="form-group">
                    <label for="vol-interest">How would you like to help?</label>
                    <select id="vol-interest" name="interest">
                        <option value="">Select one...</option>
                        <option value="canvass">Door Knocking / Canvassing</option>
                        <option value="phonebank">Phone Banking</option>
                        <option value="yardsign">Yard Sign Request</option>
                        <option value="host">Host an Event</option>
                        <option value="other">Other / Anything Needed</option>
                    </select>
                </div>
                <button type="submit" class="btn volunteer-submit-btn">Count Me In</button>
            </form>
        </div>
    </div>
</section>

<!-- Yard Sign CTA -->
<section class="yard-sign-section reveal">
    <div class="yard-sign-content">
        <div class="yard-sign-icon">
            <i class="fas fa-signs-post"></i>
        </div>
        <div class="yard-sign-text">
            <h2>Request a Yard Sign</h2>
            <p>Show your neighbors you support Eric Stafford for Arizona Senate. We'll deliver a free yard sign right to your door.</p>
        </div>
        <form class="yard-sign-form" name="yard-sign-request" method="POST" data-netlify="true" action="/thank-you">
            <input type="hidden" name="form-name" value="yard-sign-request">
            <input type="text" name="name" placeholder="Full Name" required>
            <input type="text" name="address" placeholder="Street Address" required>
            <input type="text" name="city" placeholder="City" required>
            <input type="text" name="zip" placeholder="Zip Code" pattern="[0-9]{5}" required>
            <button type="submit" class="btn yard-sign-btn">Send Me a Sign</button>
        </form>
    </div>
</section>

<!-- Endorsements Preview -->
<section class="endorsements-preview-section reveal">
    <div class="endorsements-preview-content">
        <h2>Endorsed By</h2>
        <p class="endorsements-subtitle">Eric is proud to be supported by workers, community leaders, and organizations across LD29.</p>
        <div class="endorsements-preview-grid">
            <div class="endorsement-card">
                <i class="fas fa-hard-hat"></i>
                <span>Labor & Trade Unions</span>
            </div>
            <div class="endorsement-card">
                <i class="fas fa-chalkboard-teacher"></i>
                <span>Educators & Teachers</span>
            </div>
            <div class="endorsement-card">
                <i class="fas fa-store"></i>
                <span>Small Business Owners</span>
            </div>
            <div class="endorsement-card">
                <i class="fas fa-people-carry-box"></i>
                <span>Community Leaders</span>
            </div>
        </div>
        <a href="/endorsements" class="btn endorsements-link-btn">See All Endorsements</a>
    </div>
</section>

</BaseLayout>

<style>
/* Events Intro */
.events-intro {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 40px 20px;
    text-align: center;
}

.events-intro h2 {
    font-size: 36px;
    font-weight: 700;
    color: var(--main-blue);
    text-transform: uppercase;
    margin-bottom: 16px;
}

.events-intro p {
    font-size: 18px;
    line-height: 1.7;
    color: var(--main-blue);
    opacity: 0.9;
}

/* Calendar Section */
.events-calendar-section {
    padding: 20px 40px 60px;
}

/* Volunteer Section */
.volunteer-section {
    background: linear-gradient(var(--main-blue), #122940);
    padding: 80px 40px;
    position: relative;
    overflow: hidden;
}

.volunteer-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: url(/assets/background.webp);
    background-size: cover;
    background-position: center;
    filter: grayscale(100%) contrast(200%);
    opacity: 0.06;
    z-index: 1;
}

.volunteer-content {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
}

.volunteer-text {
    color: var(--off-white);
}

.volunteer-text h2 {
    font-size: 36px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 16px;
}

.volunteer-text p {
    font-size: 17px;
    line-height: 1.7;
    opacity: 0.9;
    margin-bottom: 30px;
}

.volunteer-ways {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.volunteer-ways li {
    display: flex;
    align-items: flex-start;
    gap: 16px;
}

.volunteer-ways li i {
    font-size: 22px;
    color: var(--bg-orange);
    margin-top: 4px;
    min-width: 28px;
    text-align: center;
}

.volunteer-ways li strong {
    display: block;
    font-size: 16px;
    margin-bottom: 2px;
}

.volunteer-ways li span {
    font-size: 14px;
    opacity: 0.75;
}

/* Volunteer Form */
.volunteer-form-wrapper {
    background: var(--off-white);
    padding: 36px;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

.volunteer-form-wrapper h3 {
    font-size: 24px;
    font-weight: 700;
    color: var(--main-blue);
    text-transform: uppercase;
    margin-bottom: 24px;
}

.volunteer-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.volunteer-form .form-group {
    display: flex;
    flex-direction: column;
}

.volunteer-form label {
    font-weight: 600;
    margin-bottom: 5px;
    font-size: 14px;
    color: var(--main-blue);
}

.volunteer-form input,
.volunteer-form select {
    padding: 12px;
    border: 1px solid var(--bg-dark-green);
    border-radius: 4px;
    font-size: 16px;
    font-family: 'Work Sans', sans-serif;
    outline: none;
    transition: border-color 0.3s;
}

.volunteer-form input:focus,
.volunteer-form select:focus {
    border-color: var(--main-blue);
    box-shadow: 0 0 0 2px var(--main-blue);
}

.volunteer-submit-btn {
    margin-top: 8px;
    background: var(--main-blue);
    color: var(--off-white);
    border-color: var(--main-blue);
}

.volunteer-submit-btn:hover {
    background: transparent;
    color: var(--main-blue);
}

/* Yard Sign Section */
.yard-sign-section {
    background: var(--bg-orange);
    padding: 50px 40px;
}

.yard-sign-content {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 30px;
    flex-wrap: wrap;
    justify-content: center;
}

.yard-sign-icon {
    font-size: 48px;
    color: var(--main-blue);
    flex-shrink: 0;
}

.yard-sign-text {
    flex: 1;
    min-width: 250px;
}

.yard-sign-text h2 {
    font-size: 28px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    margin-bottom: 6px;
}

.yard-sign-text p {
    font-size: 16px;
    color: var(--main-blue);
    opacity: 0.85;
    line-height: 1.5;
}

.yard-sign-form {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
}

.yard-sign-form input {
    padding: 12px 14px;
    border: 2px solid var(--main-blue);
    border-radius: 4px;
    font-size: 15px;
    font-family: 'Work Sans', sans-serif;
    background: var(--off-white);
    outline: none;
    min-width: 140px;
    flex: 1;
}

.yard-sign-form input:focus {
    box-shadow: 0 0 0 2px var(--main-blue);
}

.yard-sign-btn {
    background: var(--main-blue);
    color: var(--off-white);
    border-color: var(--main-blue);
    flex-shrink: 0;
}

.yard-sign-btn:hover {
    background: transparent;
    color: var(--main-blue);
}

/* Endorsements Preview */
.endorsements-preview-section {
    padding: 80px 40px;
    text-align: center;
    background: var(--off-white);
}

.endorsements-preview-content {
    max-width: 900px;
    margin: 0 auto;
}

.endorsements-preview-content h2 {
    font-size: 36px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    margin-bottom: 10px;
}

.endorsements-subtitle {
    font-size: 17px;
    color: var(--main-blue);
    opacity: 0.85;
    margin-bottom: 40px;
    line-height: 1.6;
}

.endorsements-preview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    margin-bottom: 40px;
}

.endorsement-card {
    background: white;
    border: 2px solid rgba(23, 60, 98, 0.1);
    border-radius: 8px;
    padding: 30px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    transition: transform 0.3s, box-shadow 0.3s;
}

.endorsement-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
}

.endorsement-card i {
    font-size: 32px;
    color: var(--bg-orange);
}

.endorsement-card span {
    font-size: 15px;
    font-weight: 700;
    color: var(--main-blue);
    text-align: center;
}

.endorsements-link-btn {
    border-color: var(--main-blue);
    color: var(--main-blue);
}

.endorsements-link-btn:hover {
    background: var(--main-blue);
    color: var(--off-white);
}

/* Responsive */
@media (max-width: 768px) {
    .events-intro {
        padding: 40px 20px 10px;
    }

    .events-intro h2 {
        font-size: 28px;
    }

    .events-calendar-section {
        padding: 10px 10px 40px;
    }

    .volunteer-section {
        padding: 50px 20px;
    }

    .volunteer-content {
        grid-template-columns: 1fr;
        gap: 40px;
    }

    .volunteer-text h2 {
        font-size: 28px;
    }

    .yard-sign-section {
        padding: 40px 20px;
    }

    .yard-sign-content {
        flex-direction: column;
        text-align: center;
    }

    .yard-sign-form {
        flex-direction: column;
        width: 100%;
    }

    .yard-sign-form input {
        width: 100%;
    }

    .endorsements-preview-section {
        padding: 50px 20px;
    }

    .endorsements-preview-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }
}

@media (max-width: 480px) {
    .events-intro h2 {
        font-size: 24px;
    }

    .events-intro p {
        font-size: 16px;
    }

    .volunteer-form-wrapper {
        padding: 24px 20px;
    }

    .endorsements-preview-grid {
        grid-template-columns: 1fr;
    }
}
</style>