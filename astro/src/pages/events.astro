---
// Import the layout
import BaseLayout from '../layouts/BaseLayout.astro';
import Schedule from '../components/Calendar.astro';
import siteText from '../data/site-text.json';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford for Arizona Senate - Events";
const pageUrl = '/events';
const pageDescription = "Find upcoming events, town halls, and volunteer opportunities for Eric Stafford's Arizona Senate campaign in LD29.";
const eventsText = siteText.events;
const eventsForm = eventsText.form;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="mini-hero">
    <div class="mini-hero-content">
        <h2>{eventsText.heroTitle}</h2>
    </div>
</section>

<!-- Events Intro -->
<section class="events-intro">
    <div class="events-intro-content">
        <h2>{eventsText.introTitle}</h2>
        <p>{eventsText.introBody}</p>
    </div>
</section>

<!-- Calendar Section -->
<section class="events-calendar-section">
    <Schedule />
</section>

<!-- Volunteer CTA Section -->
<section class="volunteer-section">
    <div class="volunteer-content">
        <div class="volunteer-text">
            <h2>{eventsText.volunteerTitle}</h2>
            <p>{eventsText.volunteerBody}</p>
            <ul class="volunteer-ways">
                <li>
                    <i class="fas fa-door-open"></i>
                    <div>
                        <strong>{eventsText.volunteerWays[0].title}</strong>
                        <span>{eventsText.volunteerWays[0].description}</span>
                    </div>
                </li>
                <li>
                    <i class="fas fa-phone"></i>
                    <div>
                        <strong>{eventsText.volunteerWays[1].title}</strong>
                        <span>{eventsText.volunteerWays[1].description}</span>
                    </div>
                </li>
                <li>
                    <i class="fas fa-signs-post"></i>
                    <div>
                        <strong>{eventsText.volunteerWays[2].title}</strong>
                        <span>{eventsText.volunteerWays[2].description}</span>
                    </div>
                </li>
                <li>
                    <i class="fas fa-people-group"></i>
                    <div>
                        <strong>{eventsText.volunteerWays[3].title}</strong>
                        <span>{eventsText.volunteerWays[3].description}</span>
                    </div>
                </li>
            </ul>
        </div>
        <div class="volunteer-form-wrapper">
            <h3>{eventsText.volunteerFormTitle}</h3>
            <form class="volunteer-form" name="volunteer-signup" method="POST" data-netlify="true">
                <input type="hidden" name="form-name" value="volunteer-signup">
                <div class="form-group">
                    <label for="vol-name">{eventsForm.nameLabel}</label>
                    <input type="text" id="vol-name" name="name" required>
                </div>
                <div class="form-group">
                    <label for="vol-email">{eventsForm.emailLabel}</label>
                    <input type="email" id="vol-email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="vol-phone">{eventsForm.phoneLabel}</label>
                    <input type="tel" id="vol-phone" name="phone">
                </div>
                <div class="form-group">
                    <label for="vol-zip">{eventsForm.zipLabel}</label>
                    <input type="text" id="vol-zip" name="zip" pattern="[0-9]{5}" title={eventsForm.zipTitle}>
                </div>
                <div class="form-group">
                    <label for="vol-interest">{eventsForm.interestLabel}</label>
                    <select id="vol-interest" name="interest">
                        <option value="">{eventsForm.interestPlaceholder}</option>
                        {eventsForm.interestOptions.map((option) => (
                            <option value={option.value}>{option.label}</option>
                        ))}
                    </select>
                </div>
                <button type="submit" class="btn volunteer-submit-btn">{eventsText.volunteerSubmit}</button>
            </form>
        </div>
    </div>
</section>

</BaseLayout>

<style>
/* Events Intro */
.events-intro {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 40px 20px;
    text-align: center;
}

.events-intro h2 {
    font-size: 36px;
    font-weight: 700;
    color: var(--main-blue);
    text-transform: uppercase;
    margin-bottom: 16px;
}

.events-intro p {
    font-size: 18px;
    line-height: 1.7;
    color: var(--main-blue);
    opacity: 0.9;
}

/* Calendar Section */
.events-calendar-section {
    padding: 20px 40px 60px;
}

/* Volunteer Section */
.volunteer-section {
    background: linear-gradient(var(--main-blue), #122940);
    padding: 80px 40px;
    position: relative;
    overflow: hidden;
}

.volunteer-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: url(/assets/background.webp);
    background-size: cover;
    background-position: center;
    filter: grayscale(100%) contrast(200%);
    opacity: 0.06;
    z-index: 1;
}

.volunteer-content {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
}

.volunteer-text {
    color: var(--off-white);
}

.volunteer-text h2 {
    font-size: 36px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 16px;
}

.volunteer-text p {
    font-size: 17px;
    line-height: 1.7;
    opacity: 0.9;
    margin-bottom: 30px;
}

.volunteer-ways {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.volunteer-ways li {
    display: flex;
    align-items: flex-start;
    gap: 16px;
}

.volunteer-ways li i {
    font-size: 22px;
    color: var(--bg-orange);
    margin-top: 4px;
    min-width: 28px;
    text-align: center;
}

.volunteer-ways li strong {
    display: block;
    font-size: 16px;
    margin-bottom: 2px;
}

.volunteer-ways li span {
    font-size: 14px;
    opacity: 0.75;
}

/* Volunteer Form */
.volunteer-form-wrapper {
    background: var(--off-white);
    padding: 36px;
    border-radius: 8px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

.volunteer-form-wrapper h3 {
    font-size: 24px;
    font-weight: 700;
    color: var(--main-blue);
    text-transform: uppercase;
    margin-bottom: 24px;
}

.volunteer-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.volunteer-form .form-group {
    display: flex;
    flex-direction: column;
}

.volunteer-form label {
    font-weight: 600;
    margin-bottom: 5px;
    font-size: 14px;
    color: var(--main-blue);
}

.volunteer-form input,
.volunteer-form select {
    padding: 12px;
    border: 1px solid var(--bg-dark-green);
    border-radius: 4px;
    font-size: 16px;
    font-family: 'Work Sans', sans-serif;
    outline: none;
    transition: border-color 0.3s;
}

.volunteer-form input:focus,
.volunteer-form select:focus {
    border-color: var(--main-blue);
    box-shadow: 0 0 0 2px var(--main-blue);
}

.volunteer-submit-btn {
    margin-top: 8px;
    background: var(--main-blue);
    color: var(--off-white);
    border-color: var(--main-blue);
}

.volunteer-submit-btn:hover {
    background: transparent;
    color: var(--main-blue);
}

/* Responsive */
@media (max-width: 768px) {
    .events-intro {
        padding: 40px 20px 10px;
    }

    .events-intro h2 {
        font-size: 28px;
    }

    .events-calendar-section {
        padding: 10px 10px 40px;
    }

    .volunteer-section {
        padding: 50px 20px;
    }

    .volunteer-content {
        grid-template-columns: 1fr;
        gap: 40px;
    }

    .volunteer-text h2 {
        font-size: 28px;
    }
}

@media (max-width: 480px) {
    .events-intro h2 {
        font-size: 24px;
    }

    .events-intro p {
        font-size: 16px;
    }

    .volunteer-form-wrapper {
        padding: 24px 20px;
    }
}
</style>