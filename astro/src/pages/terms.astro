---
// Import the layout
import BaseLayout from '../layouts/BaseLayout.astro';
import siteText from '../data/site-text.json';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford for Arizona Senate - Terms & Conditions";
const pageUrl = '/terms';
const pageDescription = "Read the official Terms & Conditions for Eric Stafford's campaign for Arizona Senate, including information on donations, volunteer activities, and communications for Eric Stafford in LD29.";
const links = siteText.global.links;
const termsText = siteText.terms;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="mini-hero">
    <div class="mini-hero-content">
        <h2>{termsText.heroTitle}</h2>
    </div>
</section>

<section class="terms-content">
  <div class="legal-header">
            <h2>{termsText.headerTitle}</h2>
            <p class="legal-meta">{termsText.meta}</p>
  </div>

    {termsText.sections.map((section, index) => (
        <div class="legal-section">
            <h3><span class="section-num">{index + 1}</span> {section.title}</h3>
            {section.title === 'Privacy & Data Use' ? (
                <p>We collect names, emails, phone numbers, and ZIP codes for campaign communications only. We will not sell or share your information with third parties. For more, see our <a href={links.privacy}>Privacy Policy</a>.</p>
            ) : section.title === 'Contact Information' ? (
                <p>If you have questions, please <a href={links.contact}>contact us</a>.</p>
            ) : (
                <p>{section.body}</p>
            )}
            {section.highlight && <div class="legal-disclosure-box">{section.highlight}</div>}
            {section.title === 'Contact Information' && (
                <div class="legal-contact-box">
                    {termsText.contactBox}
                </div>
            )}
        </div>
    ))}

  <div class="legal-disclosures">
            <h3>{termsText.additionalDisclosuresTitle}</h3>
      <div class="disclosure-items">
                    {termsText.additionalDisclosures.map((disclosure) => (
                        <div class="disclosure-item">
                            <strong>{disclosure.title}</strong>
                            {disclosure.title === 'Accessibility' ? (
                                <p>We are committed to website accessibility. <a href={links.contact}>Contact us</a> if you experience difficulties.</p>
                            ) : (
                                <p>{disclosure.body}</p>
                            )}
                        </div>
                    ))}
      </div>
  </div>

    <p class="legal-closing">{termsText.closing}</p>
</section>

</BaseLayout>

<style>
.terms-content {
    max-width: 780px;
    margin: 0 auto;
    padding: 50px 40px 70px;
}

.legal-header {
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 2px solid rgba(23, 60, 98, 0.1);
}

.legal-header h2 {
    font-size: 32px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    margin-bottom: 8px;
}

.legal-meta {
    font-size: 14px;
    color: var(--main-blue);
    opacity: 0.55;
}

.legal-section {
    margin-bottom: 28px;
    padding-bottom: 28px;
    border-bottom: 1px solid rgba(23, 60, 98, 0.06);
}

.legal-section:last-of-type {
    border-bottom: none;
}

.legal-section h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--main-blue);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.section-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(254, 166, 85, 0.15);
    color: var(--bg-orange);
    font-size: 13px;
    font-weight: 800;
    flex-shrink: 0;
}

.legal-section p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--main-blue);
    opacity: 0.85;
}

.legal-section a {
    color: var(--bg-orange);
    text-decoration: underline;
}

.legal-disclosure-box {
    margin-top: 12px;
    padding: 12px 18px;
    background: rgba(23, 60, 98, 0.04);
    border: 2px solid rgba(23, 60, 98, 0.1);
    border-radius: 6px;
    font-size: 14px;
    font-weight: 800;
    color: var(--main-blue);
    text-align: center;
    letter-spacing: 0.5px;
}

.legal-contact-box {
    margin-top: 12px;
    padding: 14px 18px;
    background: rgba(23, 60, 98, 0.04);
    border-left: 3px solid var(--main-blue);
    border-radius: 0 6px 6px 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--main-blue);
}

.legal-disclosures {
    margin-top: 36px;
    padding: 28px;
    background: rgba(254, 166, 85, 0.06);
    border-radius: 8px;
    border: 1px solid rgba(254, 166, 85, 0.15);
}

.legal-disclosures h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--main-blue);
    margin-bottom: 16px;
}

.disclosure-items {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.disclosure-item strong {
    font-size: 14px;
    color: var(--main-blue);
    display: block;
    margin-bottom: 4px;
}

.disclosure-item p {
    font-size: 14px;
    line-height: 1.65;
    color: var(--main-blue);
    opacity: 0.75;
    margin: 0;
}

.disclosure-item a {
    color: var(--bg-orange);
    text-decoration: underline;
}

.legal-closing {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 2px solid rgba(23, 60, 98, 0.1);
    font-size: 15px;
    line-height: 1.7;
    color: var(--main-blue);
    opacity: 0.7;
    font-style: italic;
}

@media (max-width: 768px) {
    .terms-content {
        padding: 30px 20px 50px;
    }

    .legal-header h2 {
        font-size: 26px;
    }

    .legal-disclosures {
        padding: 20px;
    }
}
</style>