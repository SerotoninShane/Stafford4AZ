---
// Import the layout
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoThumbnail from '../components/VideoThumbnail.astro';
import VideoModal from '../components/VideoModal.astro';
import siteText from '../data/site-text.json';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford For LD29 Arizona Senate | Putting Arizonans First";
const pageUrl = '/';
const pageDescription = "View Eric Stafford's detailed platform on education, water, and economic development for LD29 and Arizona.";
const links = siteText.global.links;
const homeText = siteText.home;
const homeForm = homeText.form;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>


<!-- Hero Section -->
<section class="hero" id="home">
    <div class="hero-content-wrapper">
        <div class="hero-text-and-buttons">
            <h1>
                {homeText.heroTitle}
            </h1>
            <div class="hero-buttons">
                <a href={links.platform} class="btn">{homeText.heroPrimaryCta}</a>
                <a href={links.donate} class="btn" target="_blank">{homeText.heroDonateCta}</a>
            </div>
        </div>
        <div class="hero-headshot-container">
            <img src="/assets/eric.webp" alt="Eric Stafford Headshot" width="600" height="400" loading="eager">
        </div>
    </div>
</section>

<!-- About / Signup Section -->
<section class="about-section" id="contact">
    <div class="about-image"> 
        <h2>{homeText.signupTitle}</h2>
        <p class="disclaimer-large">
            {homeText.signupDisclaimer}
        </p>
    </div>
    
    <div class="about-content">
    <form class="campaign-form" name="campaign-signup" method="POST" data-netlify="true" action={links.thankYou}>
            <input type="hidden" name="form-name" value="campaign-signup">

            <div class="form-row">
                <div class="form-group">
                    <label for="first-name">{homeForm.firstNameLabel}</label>
                    <input type="text" id="first-name" name="first-name" required>
                </div>
                <div class="form-group">
                    <label for="last-name">{homeForm.lastNameLabel}</label>
                    <input type="text" id="last-name" name="last-name" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="zip-code">{homeForm.zipCodeLabel}</label>
                    <input type="text" id="zip-code" name="zip-code" pattern="[0-9]{5}" title="Please enter a 5-digit zip code" required>
                </div>
                <div class="form-group">
                    <label for="phone">{homeForm.phoneLabel}</label>
                    <input type="tel" id="phone" name="phone">
                </div>
            </div>

            <div class="form-group full-width">
                <label for="email">{homeForm.emailLabel}</label>
                <input type="email" id="email" name="email" required>
            </div>
            
            <button type="submit" class="btn submit-btn">{homeForm.submitLabel}</button>
        </form>
    </div>
</section>

<!-- Voter Resources CTA -->
<section class="home-voter-cta reveal">
    <div class="home-voter-cta-content">
        <div class="home-voter-cta-actions">
            <a href={links.voterResources} class="btn home-voter-btn">{homeText.voterResourcesLabel}</a>
            <a href={links.checkVoterStatus} class="btn home-voter-btn-secondary" target="_blank" rel="noopener">{homeText.inDistrictLabel}</a>
        </div>
        <div class="home-voter-cta-text">
            <h2>{homeText.voterCtaTitle}</h2>
            <p>{homeText.voterCtaBody}</p>
        </div>
    </div>
</section>

<!-- Video Section -->
<section class="video-section reveal" id="video">
    <div class="video-content-wrapper">
        <div class="video-text">
            <h2>{homeText.videoTitle}</h2>
            <p>{homeText.videoBody}</p>
        </div>
    </div>
    <VideoThumbnail />
</section>

<!-- Video Modal -->
<VideoModal />

</div>

<!-- Donate Section -->
<section class="donate-section reveal">
    <h2>
        {homeText.donateTitleLines[0]}<br>
        {homeText.donateTitleLines[1]}<br>
        {homeText.donateTitleLines[2]}
    </h2>
    <div class="donate-amounts">
        <a href={links.donate5} target="_blank">
        <button class="donate-amount-btn" data-amount="5">$5</button>
        </a>
        <a href={links.donate10} target="_blank">
        <button class="donate-amount-btn" data-amount="10">$10</button>
        </a>
        <a href={links.donate25} target="_blank">
        <button class="donate-amount-btn" data-amount="25">$25</button>
        </a>
        <a href={links.donate50} target="_blank">
        <button class="donate-amount-btn" data-amount="50">$50</button>
        </a>
        <a href={links.donate100} target="_blank">
        <button class="donate-amount-btn" data-amount="100">$100</button>
        </a>
        <a href={links.donate} target="_blank">
        <button class="donate-amount-btn other" data-amount="other">{homeText.donateOtherLabel}</button>
        </a>
    </div>
</section>

<!-- Platform Section -->
<section class="platform-section reveal" id="platform">
    <div class="platform-image-container">
        <img src="/assets/vote.webp" alt="Eric Stafford State Senator Candidate Holding Vote Hat" width="600" height="400" loading="lazy" style="max-width:100%;height:auto;">
    </div>
    <div class="platform-content-wrapper">
        <div class="platform-text">
            <h2>{homeText.platformTitle}</h2>
            <p>
                {homeText.platformBody}
            </p>
        </div>
    </div>
</section>

</BaseLayout>

<style>
/* Home Voter Resources CTA */
.home-voter-cta {
    background: linear-gradient(135deg, var(--main-blue), #122940);
    padding: 60px 60px;
}

.home-voter-cta-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    max-width: 1100px;
    margin: 0 auto;
}

.home-voter-cta-text h2 {
    font-size: 30px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--off-white);
    margin-bottom: 12px;
}

.home-voter-cta-text p {
    font-size: 16px;
    color: var(--off-white);
    opacity: 0.85;
    line-height: 1.7;
    max-width: 480px;
}

.home-voter-cta-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-shrink: 0;
}

.home-voter-btn {
    background: var(--bg-orange);
    border-color: var(--bg-orange);
    color: var(--main-blue);
    padding: 14px 32px;
    font-weight: 700;
    text-align: center;
}

.home-voter-btn:hover {
    background: #e8943e;
    border-color: #e8943e;
}

.home-voter-btn-secondary {
    border-color: var(--off-white);
    color: var(--off-white);
    padding: 14px 32px;
    text-align: center;
}

.home-voter-btn-secondary:hover {
    background: var(--off-white);
    color: var(--main-blue);
}

@media (max-width: 768px) {
    .home-voter-cta {
        padding: 40px 20px;
    }

    .home-voter-cta-content {
        flex-direction: column;
        text-align: center;
    }

    .home-voter-cta-text h2 {
        font-size: 24px;
    }

    .home-voter-cta-actions {
        width: 100%;
    }
}
</style>