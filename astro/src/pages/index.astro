---
// Import the layout
import BaseLayout from '../layouts/BaseLayout.astro';
import VideoThumbnail from '../components/VideoThumbnail.astro';
import VideoModal from '../components/VideoModal.astro';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford For LD29 Arizona Senate | Putting Arizonans First";
const pageUrl = '/';
const pageDescription = "View Eric Stafford's detailed platform on education, water, and economic development for LD29 and Arizona.";
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>


<!-- Hero Section -->
<section class="hero" id="home">
    <div class="hero-content-wrapper">
        <div class="hero-text-and-buttons">
            <h1>
                Eric Stafford: Arizonans First. Arizona Always.
            </h1>
            <div class="hero-buttons">
                <a href="/platform" class="btn">SEE WHERE I STAND</a>
                <a href="https://secure.actblue.com/donate/stafford-4-az-1?refcode=directory" class="btn" target="_blank">DONATE</a>
            </div>
        </div>
        <div class="hero-headshot-container">
            <img src="/assets/eric.webp" alt="Eric Stafford Headshot" width="600" height="400" loading="eager">
        </div>
    </div>
</section>

<!-- About / Signup Section -->
<section class="about-section" id="contact">
    <div class="about-image"> 
        <h2>Stay Up to Date on Eric's Campaign</h2>
        <p class="disclaimer-large">
            By submitting your phone number you are agreeing to receive up to 1 text message(s) per day from Eric Stafford for Arizona Senate. Eric Stafford for Arizona Senate's mobile campaigns provide subscribers with updates, event invitations, donation asks, and voting reminders. Messages may include donation asks. Message and data rates may apply. Text HELP for more information. Text STOP to stop receiving messages. See Terms of Service/Privacy Policy.
        </p>
    </div>
    
    <div class="about-content">
        <form class="campaign-form" name="campaign-signup" method="POST" data-netlify="true" action="/thank-you">
            <input type="hidden" name="form-name" value="campaign-signup">

            <div class="form-row">
                <div class="form-group">
                    <label for="first-name">First Name (required)</label>
                    <input type="text" id="first-name" name="first-name" required>
                </div>
                <div class="form-group">
                    <label for="last-name">Last Name (required)</label>
                    <input type="text" id="last-name" name="last-name" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="zip-code">Zip Code (required)</label>
                    <input type="text" id="zip-code" name="zip-code" pattern="[0-9]{5}" title="Please enter a 5-digit zip code" required>
                </div>
                <div class="form-group">
                    <label for="phone">Phone</label>
                    <input type="tel" id="phone" name="phone">
                </div>
            </div>

            <div class="form-group full-width">
                <label for="email">Email (required)</label>
                <input type="email" id="email" name="email" required>
            </div>
            
            <button type="submit" class="btn submit-btn">Submit</button>
        </form>
    </div>
</section>

<!-- Voter Resources CTA -->
<section class="home-voter-cta reveal">
    <div class="home-voter-cta-content">
        <div class="home-voter-cta-actions">
            <a href="/voter-resources" class="btn home-voter-btn">Voter Resources</a>
            <a href="https://my.arizona.vote/WhereDoIVote.aspx?s=address" class="btn home-voter-btn-secondary" target="_blank" rel="noopener">Am I in LD29?</a>
        </div>
        <div class="home-voter-cta-text">
            <h2>Are You Ready to Vote?</h2>
            <p>Check if you're in LD29, register to vote, find your polling place, and learn about early voting — everything you need in one place.</p>
        </div>
    </div>
</section>

<!-- Video Section -->
<section class="video-section reveal" id="video">
    <div class="video-content-wrapper">
        <div class="video-text">
            <h2>See Eric's Vision for Arizona</h2>
            <p>Join Eric Stafford as he shares his vision for LD29 and how he’ll prioritize Arizona families. See how Eric Stafford will lower the cost of living, support fair wages, strengthen schools, and run a clean, accountable government. Watch the video to see how his people-first leadership can create a brighter future for all families in LD29.</p>
        </div>
    </div>
    <VideoThumbnail />
</section>

<!-- Video Modal -->
<VideoModal />

</div>

<!-- Donate Section -->
<section class="donate-section reveal">
    <h2>
        DONATE TO<br>
        Eric Stafford<br>
        for Senate
    </h2>
    <div class="donate-amounts">
        <a href="https://secure.actblue.com/donate/stafford-4-az-1?refcode=directory&amount=5" target="_blank">
        <button class="donate-amount-btn" data-amount="5">$5</button>
        </a>
        <a href="https://secure.actblue.com/donate/stafford-4-az-1?refcode=directory&amount=10" target="_blank">
        <button class="donate-amount-btn" data-amount="10">$10</button>
        </a>
        <a href="https://secure.actblue.com/donate/stafford-4-az-1?refcode=directory&amount=25" target="_blank">
        <button class="donate-amount-btn" data-amount="25">$25</button>
        </a>
        <a href="https://secure.actblue.com/donate/stafford-4-az-1?refcode=directory&amount=50" target="_blank">
        <button class="donate-amount-btn" data-amount="50">$50</button>
        </a>
        <a href="https://secure.actblue.com/donate/stafford-4-az-1?refcode=directory&amount=100" target="_blank">
        <button class="donate-amount-btn" data-amount="100">$100</button>
        </a>
        <a href="https://secure.actblue.com/donate/stafford-4-az-1?refcode=directory" target="_blank">
        <button class="donate-amount-btn other" data-amount="other">OTHER</button>
        </a>
    </div>
</section>

<!-- Platform Section -->
<section class="platform-section reveal" id="platform">
    <div class="platform-image-container">
        <img src="/assets/vote.webp" alt="Eric Stafford State Senator Candidate Holding Vote Hat" width="600" height="400" loading="lazy" style="max-width:100%;height:auto;">
    </div>
    <div class="platform-content-wrapper">
        <div class="platform-text">
            <h2>Where I Stand</h2>
            <p>
                Arizona is becoming increasingly unaffordable for families in LD29, as rising housing costs, stagnant wages, and limited access to quality education make life harder, while corruption and special interests shape policies that should serve the people. I’m running to put LD29 families first, fight for fair wages, strong schools, affordable housing, and a government that is truly accountable to everyone.
            </p>
        </div>
    </div>
</section>

</BaseLayout>

<style>
/* Home Voter Resources CTA */
.home-voter-cta {
    background: linear-gradient(135deg, var(--main-blue), #122940);
    padding: 60px 60px;
}

.home-voter-cta-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    max-width: 1100px;
    margin: 0 auto;
}

.home-voter-cta-text h2 {
    font-size: 30px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--off-white);
    margin-bottom: 12px;
}

.home-voter-cta-text p {
    font-size: 16px;
    color: var(--off-white);
    opacity: 0.85;
    line-height: 1.7;
    max-width: 480px;
}

.home-voter-cta-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex-shrink: 0;
}

.home-voter-btn {
    background: var(--bg-orange);
    border-color: var(--bg-orange);
    color: var(--main-blue);
    padding: 14px 32px;
    font-weight: 700;
    text-align: center;
}

.home-voter-btn:hover {
    background: #e8943e;
    border-color: #e8943e;
}

.home-voter-btn-secondary {
    border-color: var(--off-white);
    color: var(--off-white);
    padding: 14px 32px;
    text-align: center;
}

.home-voter-btn-secondary:hover {
    background: var(--off-white);
    color: var(--main-blue);
}

@media (max-width: 768px) {
    .home-voter-cta {
        padding: 40px 20px;
    }

    .home-voter-cta-content {
        flex-direction: column;
        text-align: center;
    }

    .home-voter-cta-text h2 {
        font-size: 24px;
    }

    .home-voter-cta-actions {
        width: 100%;
    }
}
</style>