---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "Thank You - Eric Stafford for Arizona Senate";
const pageUrl = '/thank-you';
const pageDescription = "Thank you for reaching out to Eric Stafford's campaign for Arizona State Senate.";
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="thankyou-page">
    <div class="thankyou-content">
        <div class="thankyou-icon">
            <i class="fas fa-check-circle"></i>
        </div>
        <h1>Thank You!</h1>
        <p>Your message has been received. Our team will get back to you as soon as possible.</p>
        <p class="thankyou-sub">In the meantime, here are some ways to stay connected:</p>
        <div class="thankyou-actions">
            <a href="/get-involved" class="btn thankyou-btn-primary">Get Involved</a>
            <a href="/platform" class="btn thankyou-btn-secondary">Read Eric's Platform</a>
        </div>
        <div class="thankyou-social">
            <span>Follow the campaign:</span>
            <div class="thankyou-social-icons">
                <a href="https://bsky.app/profile/stafford4az.bsky.social" aria-label="Bluesky" target="_blank" rel="noopener"><i class="fab fa-bluesky"></i></a>
                <a href="https://www.instagram.com/stafford4az" aria-label="Instagram" target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a>
                <a href="https://www.youtube.com/@Stafford4AZ" aria-label="YouTube" target="_blank" rel="noopener"><i class="fab fa-youtube"></i></a>
                <a href="https://x.com/stafford4az" aria-label="X (Twitter)" target="_blank" rel="noopener"><i class="fab fa-x-twitter"></i></a>
                <a href="https://www.facebook.com/Stafford4AZ/" aria-label="Facebook" target="_blank" rel="noopener"><i class="fab fa-facebook"></i></a>
            </div>
        </div>
    </div>
</section>
</BaseLayout>

<style>
.thankyou-page {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 40px;
    text-align: center;
    background: var(--off-white);
}

.thankyou-content {
    max-width: 550px;
}

.thankyou-icon {
    font-size: 56px;
    color: #4CAF50;
    margin-bottom: 16px;
}

.thankyou-page h1 {
    font-size: 42px;
    font-weight: 800;
    color: var(--main-blue);
    text-transform: uppercase;
    margin-bottom: 16px;
}

.thankyou-page p {
    font-size: 17px;
    color: var(--main-blue);
    opacity: 0.85;
    line-height: 1.6;
    margin-bottom: 8px;
}

.thankyou-sub {
    margin-bottom: 28px !important;
    font-size: 15px !important;
    opacity: 0.7 !important;
}

.thankyou-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 36px;
}

.thankyou-btn-primary {
    background: var(--bg-orange);
    border-color: var(--bg-orange);
    color: var(--main-blue);
    padding: 14px 32px;
    font-weight: 700;
}

.thankyou-btn-primary:hover {
    background: #e8943e;
    border-color: #e8943e;
}

.thankyou-btn-secondary {
    border-color: var(--main-blue);
    color: var(--main-blue);
    padding: 14px 32px;
}

.thankyou-btn-secondary:hover {
    background: var(--main-blue);
    color: var(--off-white);
}

.thankyou-social {
    padding-top: 24px;
    border-top: 1px solid rgba(23, 60, 98, 0.1);
}

.thankyou-social span {
    display: block;
    font-size: 14px;
    color: var(--main-blue);
    opacity: 0.6;
    margin-bottom: 12px;
}

.thankyou-social-icons {
    display: flex;
    gap: 20px;
    justify-content: center;
}

.thankyou-social-icons a {
    color: var(--main-blue);
    font-size: 22px;
    opacity: 0.6;
    transition: opacity 0.3s, color 0.3s;
}

.thankyou-social-icons a:hover {
    opacity: 1;
    color: var(--bg-orange);
}

@media (max-width: 480px) {
    .thankyou-page h1 {
        font-size: 32px;
    }

    .thankyou-actions {
        flex-direction: column;
    }
}
</style>
