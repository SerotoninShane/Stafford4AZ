---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteText from '../data/site-text.json';
const pageTitle = "Thank You - Eric Stafford for Arizona Senate";
const pageUrl = '/thank-you';
const pageDescription = "Thank you for reaching out to Eric Stafford's campaign for Arizona State Senate.";
const links = siteText.global.links;
const social = siteText.global.social;
const thankYouText = siteText.thankYou;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="thankyou-page">
    <div class="thankyou-content">
        <div class="thankyou-icon">
            <i class="fas fa-check-circle"></i>
        </div>
        <h1>{thankYouText.title}</h1>
        <p>{thankYouText.message}</p>
        <p class="thankyou-sub">{thankYouText.subMessage}</p>
        <div class="thankyou-actions">
            <a href={links.getInvolved} class="btn thankyou-btn-primary">{thankYouText.primaryCta}</a>
            <a href={links.platform} class="btn thankyou-btn-secondary">{thankYouText.secondaryCta}</a>
        </div>
        <div class="thankyou-social">
            <span>{thankYouText.followLabel}</span>
            <div class="thankyou-social-icons">
                <a href={social.bluesky} aria-label={thankYouText.aria.bluesky} target="_blank" rel="noopener"><i class="fab fa-bluesky"></i></a>
                <a href={social.instagram} aria-label={thankYouText.aria.instagram} target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a>
                <a href={social.youtube} aria-label={thankYouText.aria.youtube} target="_blank" rel="noopener"><i class="fab fa-youtube"></i></a>
                <a href={social.x} aria-label={thankYouText.aria.x} target="_blank" rel="noopener"><i class="fab fa-x-twitter"></i></a>
                <a href={social.facebook} aria-label={thankYouText.aria.facebook} target="_blank" rel="noopener"><i class="fab fa-facebook"></i></a>
            </div>
        </div>
    </div>
</section>
</BaseLayout>

<style>
.thankyou-page {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 40px;
    text-align: center;
    background: var(--off-white);
}

.thankyou-content {
    max-width: 550px;
}

.thankyou-icon {
    font-size: 56px;
    color: #4CAF50;
    margin-bottom: 16px;
}

.thankyou-page h1 {
    font-size: 42px;
    font-weight: 800;
    color: var(--main-blue);
    text-transform: uppercase;
    margin-bottom: 16px;
}

.thankyou-page p {
    font-size: 17px;
    color: var(--main-blue);
    opacity: 0.85;
    line-height: 1.6;
    margin-bottom: 8px;
}

.thankyou-sub {
    margin-bottom: 28px !important;
    font-size: 15px !important;
    opacity: 0.7 !important;
}

.thankyou-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 36px;
}

.thankyou-btn-primary {
    background: var(--bg-orange);
    border-color: var(--bg-orange);
    color: var(--main-blue);
    padding: 14px 32px;
    font-weight: 700;
}

.thankyou-btn-primary:hover {
    background: #e8943e;
    border-color: #e8943e;
}

.thankyou-btn-secondary {
    border-color: var(--main-blue);
    color: var(--main-blue);
    padding: 14px 32px;
}

.thankyou-btn-secondary:hover {
    background: var(--main-blue);
    color: var(--off-white);
}

.thankyou-social {
    padding-top: 24px;
    border-top: 1px solid rgba(23, 60, 98, 0.1);
}

.thankyou-social span {
    display: block;
    font-size: 14px;
    color: var(--main-blue);
    opacity: 0.6;
    margin-bottom: 12px;
}

.thankyou-social-icons {
    display: flex;
    gap: 20px;
    justify-content: center;
}

.thankyou-social-icons a {
    color: var(--main-blue);
    font-size: 22px;
    opacity: 0.6;
    transition: opacity 0.3s, color 0.3s;
}

.thankyou-social-icons a:hover {
    opacity: 1;
    color: var(--bg-orange);
}

@media (max-width: 480px) {
    .thankyou-page h1 {
        font-size: 32px;
    }

    .thankyou-actions {
        flex-direction: column;
    }
}
</style>
