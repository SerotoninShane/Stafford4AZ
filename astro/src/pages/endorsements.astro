---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteText from '../data/site-text.json';
const pageTitle = "Eric Stafford for Arizona Senate - Endorsements";
const pageUrl = '/endorsements';
const pageDescription = "See who is endorsing Eric Stafford for Arizona State Senate in LD29. Unions, community leaders, and organizations standing with working families.";
const links = siteText.global.links;
const endorsementsText = siteText.endorsements;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="mini-hero">
    <div class="mini-hero-content">
        <h2>{endorsementsText.heroTitle}</h2>
    </div>
</section>

<section class="endorsements-page reveal">
    <div class="endorsements-header">
        <h2>{endorsementsText.headerTitle}</h2>
        <p>{endorsementsText.headerBody}</p>
    </div>

    <!-- Endorsement Categories -->
    <div class="endorsement-category">
        <h3><i class="fas fa-hard-hat"></i> {endorsementsText.categories[0].title}</h3>
    <p class="endorsement-placeholder">{endorsementsText.categories[0].description} <a href={links.contact}>reach out to our team</a>.</p>
    </div>

    <div class="endorsement-category">
        <h3><i class="fas fa-chalkboard-teacher"></i> {endorsementsText.categories[1].title}</h3>
        <p class="endorsement-placeholder">{endorsementsText.categories[1].description}</p>
    </div>

    <div class="endorsement-category">
        <h3><i class="fas fa-store"></i> {endorsementsText.categories[2].title}</h3>
        <p class="endorsement-placeholder">{endorsementsText.categories[2].description}</p>
    </div>

    <div class="endorsement-category">
        <h3><i class="fas fa-users"></i> {endorsementsText.categories[3].title}</h3>
        <p class="endorsement-placeholder">{endorsementsText.categories[3].description}</p>
    </div>

    <div class="endorsement-category">
        <h3><i class="fas fa-flag-usa"></i> {endorsementsText.categories[4].title}</h3>
        <p class="endorsement-placeholder">{endorsementsText.categories[4].description}</p>
    </div>

    <!-- CTA -->
    <div class="endorsement-cta">
        <h3>{endorsementsText.ctaTitle}</h3>
        <p>{endorsementsText.ctaBody}</p>
        <a href={links.contact} class="btn endorsement-cta-btn">{endorsementsText.ctaButton}</a>
    </div>
</section>

</BaseLayout>

<style>
.endorsements-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 40px 80px;
}

.endorsements-header {
    text-align: center;
    margin-bottom: 50px;
}

.endorsements-header h2 {
    font-size: 36px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    margin-bottom: 16px;
}

.endorsements-header p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--main-blue);
    opacity: 0.9;
}

.endorsement-category {
    margin-bottom: 40px;
    padding: 30px;
    background: white;
    border-radius: 8px;
    border-left: 5px solid var(--bg-orange);
}

.endorsement-category h3 {
    font-size: 22px;
    font-weight: 700;
    color: var(--main-blue);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
}

.endorsement-category h3 i {
    color: var(--bg-orange);
    font-size: 20px;
    min-width: 24px;
}

.endorsement-placeholder {
    font-size: 16px;
    color: var(--main-blue);
    opacity: 0.75;
    line-height: 1.6;
    font-style: italic;
}

.endorsement-placeholder a {
    color: var(--bg-orange);
    font-weight: 600;
}

.endorsement-cta {
    margin-top: 60px;
    text-align: center;
    padding: 40px;
    background: rgba(254, 166, 85, 0.1);
    border-radius: 8px;
}

.endorsement-cta h3 {
    font-size: 28px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    margin-bottom: 12px;
}

.endorsement-cta p {
    font-size: 16px;
    color: var(--main-blue);
    opacity: 0.85;
    line-height: 1.6;
    margin-bottom: 24px;
}

.endorsement-cta-btn {
    border-color: var(--main-blue);
    color: var(--main-blue);
}

.endorsement-cta-btn:hover {
    background: var(--main-blue);
    color: var(--off-white);
}

@media (max-width: 768px) {
    .endorsements-page {
        padding: 40px 20px 60px;
    }

    .endorsements-header h2 {
        font-size: 28px;
    }

    .endorsement-category {
        padding: 20px;
    }
}
</style>
