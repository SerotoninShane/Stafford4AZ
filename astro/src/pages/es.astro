---
import BaseLayout from '../layouts/BaseLayout.astro';
import siteText from '../data/site-text.json';
const pageTitle = "Eric Stafford para el Senado de Arizona - LD29 | Los Arizonenses Primero";
const pageUrl = '/es';
const pageDescription = "Eric Stafford se postula para el Senado Estatal de Arizona por el LD29. Vivienda asequible, salarios justos, escuelas sólidas — los arizonenses primero.";
const links = siteText.global.links;
const social = siteText.global.social;
const esText = siteText.es;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>

<!-- Spanish Language Notice -->
<div class="es-lang-bar">
    <p>{esText.langNotice} <a href={links.home}>{esText.viewEnglish}</a></p>
</div>

<!-- Hero -->
<section class="es-hero">
    <div class="es-hero-content">
        <h1>{esText.heroTitle}</h1>
        <p class="es-hero-sub">{esText.heroSubtitle}</p>
        <div class="es-hero-buttons">
            <a href={links.spanishPetitions} class="btn es-btn-primary">{esText.heroPetitions}</a>
            <a href={links.donate} class="btn es-btn-secondary" target="_blank">{esText.heroDonate}</a>
        </div>
    </div>
</section>

<!-- Sobre Eric -->
<section class="es-section">
    <div class="es-section-inner">
        <h2>{esText.aboutTitle}</h2>
        <div class="es-about-grid">
            <div class="es-about-image">
                <img src="/assets/eric.webp" alt="Eric Stafford" width="340" height="450" loading="eager" style="max-width:100%;height:auto;" />
            </div>
            <div class="es-about-text">
                <p>{esText.aboutParagraphs[0]}</p>
                <p>{esText.aboutParagraphs[1]}</p>
                <p>{esText.aboutParagraphs[2]}</p>
            </div>
        </div>
    </div>
</section>

<!-- Plataforma -->
<section class="es-section es-section-alt">
    <div class="es-section-inner">
        <h2>{esText.prioritiesTitle}</h2>
        <div class="es-platform-grid">
            <div class="es-platform-card">
                <i class="fas fa-house"></i>
                <h3>{esText.priorities[0].title}</h3>
                <p>{esText.priorities[0].description}</p>
            </div>
            <div class="es-platform-card">
                <i class="fas fa-hard-hat"></i>
                <h3>{esText.priorities[1].title}</h3>
                <p>{esText.priorities[1].description}</p>
            </div>
            <div class="es-platform-card">
                <i class="fas fa-graduation-cap"></i>
                <h3>{esText.priorities[2].title}</h3>
                <p>{esText.priorities[2].description}</p>
            </div>
            <div class="es-platform-card">
                <i class="fas fa-heart-pulse"></i>
                <h3>{esText.priorities[3].title}</h3>
                <p>{esText.priorities[3].description}</p>
            </div>
            <div class="es-platform-card">
                <i class="fas fa-road"></i>
                <h3>{esText.priorities[4].title}</h3>
                <p>{esText.priorities[4].description}</p>
            </div>
            <div class="es-platform-card">
                <i class="fas fa-store"></i>
                <h3>{esText.priorities[5].title}</h3>
                <p>{esText.priorities[5].description}</p>
            </div>
        </div>
        <div class="es-platform-more">
            <a href={links.platform} class="btn es-btn-outline">{esText.platformButton}</a>
        </div>
    </div>
</section>

<!-- Recursos para Votantes -->
<section class="es-section">
    <div class="es-section-inner">
        <h2>{esText.voterTitle}</h2>
        <p class="es-section-desc">{esText.voterDescription}</p>
        <div class="es-voter-grid">
            <div class="es-voter-card">
                <i class="fas fa-map-location-dot"></i>
                <h3>{esText.voterCards[0].title}</h3>
                <p>{esText.voterCards[0].description}</p>
                <a href={links.findMyDistrict} class="btn es-btn-small" target="_blank" rel="noopener">{esText.voterCards[0].button}</a>
            </div>
            <div class="es-voter-card">
                <i class="fas fa-clipboard-check"></i>
                <h3>{esText.voterCards[1].title}</h3>
                <p>{esText.voterCards[1].description}</p>
                <a href={links.registerToVote} class="btn es-btn-small" target="_blank" rel="noopener">{esText.voterCards[1].button}</a>
            </div>
            <div class="es-voter-card">
                <i class="fas fa-envelope-open-text"></i>
                <h3>{esText.voterCards[2].title}</h3>
                <p>{esText.voterCards[2].description}</p>
                <a href={links.earlyVoting} class="btn es-btn-small" target="_blank" rel="noopener">{esText.voterCards[2].button}</a>
            </div>
            <div class="es-voter-card">
                <i class="fas fa-location-dot"></i>
                <h3>{esText.voterCards[3].title}</h3>
                <p>{esText.voterCards[3].description}</p>
                <a href={links.findVoteCenter} class="btn es-btn-small" target="_blank" rel="noopener">{esText.voterCards[3].button}</a>
            </div>
        </div>
        <div class="es-key-dates">
            <h3>{esText.keyDatesTitle}</h3>
            <div class="es-dates-row">
                <div class="es-date-item">
                    <strong>{esText.keyDates[0].date}</strong>
                    <span>{esText.keyDates[0].label}</span>
                </div>
                <div class="es-date-item">
                    <strong>{esText.keyDates[1].date}</strong>
                    <span>{esText.keyDates[1].label}</span>
                </div>
                <div class="es-date-item">
                    <strong>{esText.keyDates[2].date}</strong>
                    <span>{esText.keyDates[2].label}</span>
                </div>
                <div class="es-date-item">
                    <strong>{esText.keyDates[3].date}</strong>
                    <span>{esText.keyDates[3].label}</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Participa -->
<section class="es-section es-section-dark">
    <div class="es-section-inner">
        <h2>{esText.participateTitle}</h2>
        <p class="es-section-desc-light">{esText.participateDescription}</p>
        <div class="es-involve-grid">
            <div class="es-involve-item">
                <i class="fas fa-people-group"></i>
                <h3>{esText.participateCards[0].title}</h3>
                <p>{esText.participateCards[0].description}</p>
                <a href={links.getInvolved} class="btn es-btn-orange">{esText.participateCards[0].button}</a>
            </div>
            <div class="es-involve-item">
                <i class="fas fa-sign-hanging"></i>
                <h3>{esText.participateCards[1].title}</h3>
                <p>{esText.participateCards[1].description}</p>
                <a href={`${links.getInvolved}#yard-signs`} class="btn es-btn-orange">{esText.participateCards[1].button}</a>
            </div>
            <div class="es-involve-item">
                <i class="fas fa-hand-holding-dollar"></i>
                <h3>{esText.participateCards[2].title}</h3>
                <p>{esText.participateCards[2].description}</p>
                <a href={links.donate} class="btn es-btn-orange" target="_blank">{esText.participateCards[2].button}</a>
            </div>
        </div>
    </div>
</section>

<!-- Contacto -->
<section class="es-section">
    <div class="es-section-inner es-contact-section">
        <h2>{esText.contactTitle}</h2>
        <p class="es-section-desc">{esText.contactDescription}</p>
        <a href={links.contact} class="btn es-btn-outline">{esText.contactButton}</a>
        <div class="es-social-row">
            <a href={social.facebook} target="_blank" rel="noopener"><i class="fab fa-facebook"></i></a>
            <a href={social.instagram} target="_blank" rel="noopener"><i class="fab fa-instagram"></i></a>
            <a href={social.x} target="_blank" rel="noopener"><i class="fab fa-x-twitter"></i></a>
            <a href={social.youtube} target="_blank" rel="noopener"><i class="fab fa-youtube"></i></a>
        </div>
    </div>
</section>

</BaseLayout>

<style>
/* Language Bar */
.es-lang-bar {
    background: var(--bg-orange);
    text-align: center;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--main-blue);
}

.es-lang-bar a {
    color: var(--off-white);
    text-decoration: underline;
    margin-left: 6px;
}

/* Hero */
.es-hero {
    background: linear-gradient(135deg, var(--main-blue), #122940);
    padding: 80px 40px;
    text-align: center;
    position: relative;
}

.es-hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter><rect width="100" height="100" filter="url(%23noise)" opacity="0.15"/></svg>');
    opacity: 0.4;
    z-index: 1;
}

.es-hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
}

.es-hero h1 {
    font-size: 42px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--off-white);
    margin-bottom: 12px;
    line-height: 1.2;
}

.es-hero-sub {
    font-size: 18px;
    color: var(--off-white);
    opacity: 0.8;
    margin-bottom: 30px;
}

.es-hero-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
}

.es-btn-primary {
    background: var(--bg-orange) !important;
    border-color: var(--bg-orange) !important;
    color: var(--main-blue) !important;
    padding: 14px 32px;
    font-weight: 700;
}

.es-btn-primary:hover {
    background: #e8943e !important;
    border-color: #e8943e !important;
}

.es-btn-secondary {
    border-color: var(--off-white) !important;
    color: var(--off-white) !important;
    padding: 14px 32px;
}

.es-btn-secondary:hover {
    background: var(--off-white) !important;
    color: var(--main-blue) !important;
}

/* Sections */
.es-section {
    padding: 60px 40px;
}

.es-section-alt {
    background: var(--off-white);
}

.es-section-dark {
    background: linear-gradient(135deg, var(--main-blue), #122940);
    position: relative;
}

.es-section-dark::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter><rect width="100" height="100" filter="url(%23noise)" opacity="0.15"/></svg>');
    opacity: 0.4;
    z-index: 1;
}

.es-section-dark > .es-section-inner {
    position: relative;
    z-index: 2;
}

.es-section-inner {
    max-width: 1000px;
    margin: 0 auto;
}

.es-section h2 {
    font-size: 32px;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--main-blue);
    text-align: center;
    margin-bottom: 16px;
}

.es-section-dark h2 {
    color: var(--off-white);
}

.es-section-desc {
    text-align: center;
    font-size: 16px;
    color: var(--main-blue);
    opacity: 0.8;
    margin-bottom: 36px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

.es-section-desc-light {
    text-align: center;
    font-size: 16px;
    color: var(--off-white);
    opacity: 0.8;
    margin-bottom: 36px;
}

/* About Grid */
.es-about-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 40px;
    align-items: start;
    margin-top: 30px;
}

.es-about-image img {
    width: 100%;
    border-radius: 8px;
}

.es-about-text p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--main-blue);
    opacity: 0.85;
    margin-bottom: 14px;
}

/* Platform Grid */
.es-platform-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 30px;
}

.es-platform-card {
    background: white;
    padding: 28px 22px;
    border-radius: 8px;
    border: 2px solid rgba(23, 60, 98, 0.06);
    text-align: center;
    transition: transform 0.3s, box-shadow 0.3s;
}

.es-platform-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
}

.es-platform-card i {
    font-size: 28px;
    color: var(--bg-orange);
    margin-bottom: 14px;
}

.es-platform-card h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--main-blue);
    margin-bottom: 8px;
}

.es-platform-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--main-blue);
    opacity: 0.8;
}

.es-platform-more {
    text-align: center;
    margin-top: 30px;
}

.es-btn-outline {
    border-color: var(--main-blue) !important;
    color: var(--main-blue) !important;
    padding: 12px 28px;
}

.es-btn-outline:hover {
    background: var(--main-blue) !important;
    color: var(--off-white) !important;
}

/* Voter Grid */
.es-voter-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 30px;
}

.es-voter-card {
    background: var(--off-white);
    padding: 28px 24px;
    border-radius: 8px;
    border: 2px solid rgba(23, 60, 98, 0.06);
}

.es-voter-card i {
    font-size: 24px;
    color: var(--bg-orange);
    margin-bottom: 12px;
}

.es-voter-card h3 {
    font-size: 17px;
    font-weight: 700;
    color: var(--main-blue);
    margin-bottom: 8px;
}

.es-voter-card p {
    font-size: 14px;
    line-height: 1.6;
    color: var(--main-blue);
    opacity: 0.8;
    margin-bottom: 14px;
}

.es-btn-small {
    padding: 8px 18px;
    font-size: 13px;
    border-color: var(--main-blue) !important;
    color: var(--main-blue) !important;
}

.es-btn-small:hover {
    background: var(--main-blue) !important;
    color: var(--off-white) !important;
}

/* Key Dates */
.es-key-dates {
    margin-top: 40px;
    padding: 28px;
    background: var(--off-white);
    border-radius: 8px;
    border: 2px solid rgba(254, 166, 85, 0.15);
    text-align: center;
}

.es-key-dates h3 {
    font-size: 20px;
    font-weight: 700;
    color: var(--main-blue);
    margin-bottom: 20px;
}

.es-dates-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
}

.es-date-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.es-date-item strong {
    font-size: 14px;
    color: var(--bg-orange);
}

.es-date-item span {
    font-size: 13px;
    color: var(--main-blue);
    opacity: 0.7;
}

/* Get Involved */
.es-involve-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
}

.es-involve-item {
    text-align: center;
    padding: 30px 20px;
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
}

.es-involve-item i {
    font-size: 32px;
    color: var(--bg-orange);
    margin-bottom: 14px;
}

.es-involve-item h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--off-white);
    margin-bottom: 8px;
}

.es-involve-item p {
    font-size: 14px;
    color: var(--off-white);
    opacity: 0.75;
    margin-bottom: 18px;
    line-height: 1.6;
}

.es-btn-orange {
    background: var(--bg-orange) !important;
    border-color: var(--bg-orange) !important;
    color: var(--main-blue) !important;
    padding: 10px 24px;
    font-weight: 700;
    font-size: 14px;
}

.es-btn-orange:hover {
    background: #e8943e !important;
    border-color: #e8943e !important;
}

/* Contact */
.es-contact-section {
    text-align: center;
}

.es-social-row {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 24px;
}

.es-social-row a {
    font-size: 24px;
    color: var(--main-blue);
    opacity: 0.6;
    transition: opacity 0.3s;
}

.es-social-row a:hover {
    opacity: 1;
}

/* Responsive */
@media (max-width: 768px) {
    .es-hero {
        padding: 50px 20px;
    }

    .es-hero h1 {
        font-size: 28px;
    }

    .es-section {
        padding: 40px 20px;
    }

    .es-section h2 {
        font-size: 26px;
    }

    .es-about-grid {
        grid-template-columns: 1fr;
        gap: 24px;
    }

    .es-about-image img {
        max-width: 280px;
        margin: 0 auto;
        display: block;
    }

    .es-platform-grid {
        grid-template-columns: 1fr;
    }

    .es-voter-grid {
        grid-template-columns: 1fr;
    }

    .es-dates-row {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }

    .es-involve-grid {
        grid-template-columns: 1fr;
    }

    .es-hero-buttons {
        flex-direction: column;
        align-items: center;
    }
}
</style>
