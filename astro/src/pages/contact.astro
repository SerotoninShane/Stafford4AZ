---
// Import the layout
import BaseLayout from '../layouts/BaseLayout.astro';
import siteText from '../data/site-text.json';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford for Arizona Senate - Contact";
const pageUrl = '/contact';
const pageDescription = "Contact Eric Stafford's campaign for Arizona State Senate in LD29. Questions, feedback, endorsements, and volunteer inquiries welcome.";
const links = siteText.global.links;
const contactText = siteText.contact;
const contactForm = contactText.form;
---

<BaseLayout 
    title={pageTitle} 
    canonicalUrl={pageUrl} 
    description={pageDescription}
>
<section class="mini-hero">
    <div class="mini-hero-content">
        <h2>{contactText.heroTitle}</h2>
    </div>
</section>

<section class="about-section" id="contact">
    <div class="about-image"> 
        <h2>{contactText.title}</h2>
        <p class="disclaimer-large">
            {contactText.introBody}
        </p>
    </div>
    
    <div class="about-content">
    <form class="campaign-form" name="contact-form" method="POST" data-netlify="true" action={links.thankYou}>
            <input type="hidden" name="form-name" value="contact-form">

            <div class="form-row">
                <div class="form-group">
                    <label for="contact-first-name">{contactForm.firstNameLabel}</label>
                    <input type="text" id="contact-first-name" name="first-name" required>
                </div>
                <div class="form-group">
                    <label for="contact-last-name">{contactForm.lastNameLabel}</label>
                    <input type="text" id="contact-last-name" name="last-name" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="contact-email">{contactForm.emailLabel}</label>
                    <input type="email" id="contact-email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="contact-phone">{contactForm.phoneLabel}</label>
                    <input type="tel" id="contact-phone" name="phone">
                </div>
            </div>

            <div class="form-group full-width">
                <label for="contact-subject">{contactForm.subjectLabel}</label>
                <select id="contact-subject" name="subject">
                    <option value="">{contactForm.subjectPlaceholder}</option>
                    {contactForm.subjectOptions.map((option) => (
                        <option value={option.value}>{option.label}</option>
                    ))}
                </select>
            </div>

            <div class="form-group full-width">
                <label for="contact-message">{contactForm.messageLabel}</label>
                <textarea id="contact-message" name="message" rows="5" placeholder={contactForm.messagePlaceholder} required></textarea>
            </div>
            
            <button type="submit" class="btn submit-btn">{contactText.submitLabel}</button>
        </form>
    </div>
</section>


</BaseLayout>