---
import BaseLayout from '../layouts/BaseLayout.astro';
import PlatformItem from '../components/PlatformItem.astro';
import siteText from '../data/site-text.json';
// Define the unique data for this specific page
const pageTitle = "Eric Stafford for Arizona Senate - Platform";
const pageUrl = '/platform';
const pageDescription = "View Eric Stafford's detailed platform on education, water, and economic development for Arizona.";
const platformText = siteText.platform;
---

<BaseLayout title={pageTitle} canonicalUrl={pageUrl} description={pageDescription}>

<section class="mini-hero">
  <div class="mini-hero-content">
    <h2>{platformText.heroTitle}</h2>
  </div>
</section>

<section class="platform-page-section reveal" id="platform">
  <div class="platform-page-header">
    <h2>{platformText.headerTitle}</h2>
    {platformText.introParagraphs.map((paragraph) => (
      <p class="platform-page-intro">{paragraph}</p>
    ))}
    <p class="platform-page-contact">{platformText.contactLine}</p>
  </div>

  <div class="overview-section">
    <h2>{platformText.overviewTitle}</h2>
    {platformText.overviewParagraphs.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </div>

  <ul class="platform-page-list">
    {platformText.items.map(item => (
      <PlatformItem title={item.title} content={item.content} listItems={item.listItems} />
    ))}
  </ul>
</section>

<script>
  // --- SETUP FUNCTION ---
  function initializePlatformAccordion() {
    const headers = document.querySelectorAll<HTMLButtonElement>('.platform-item-header');
    
    // Ensure elements exist before proceeding
    if (!headers || headers.length === 0) {
      return;
    }

    headers.forEach(header => {
      // 1. Prevent Listener Stacking: Check if listeners already attached
      if (header.dataset.listenerAttached === 'true') {
        return; // Skip if already has listener
      }

      header.addEventListener('click', () => {
        const content = document.getElementById(header.getAttribute('aria-controls')!);
        if (!content) return;

        const expanded = header.getAttribute('aria-expanded') === 'true';
        
        // Collapse all
        headers.forEach(h => {
          h.setAttribute('aria-expanded', 'false');
          const c = document.getElementById(h.getAttribute('aria-controls')!);
          c?.setAttribute('hidden', '');
        });

        // Expand clicked item if it wasn't already expanded
        if (!expanded) {
          header.setAttribute('aria-expanded', 'true');
          content.removeAttribute('hidden');
        }
      });

      // Mark this header as having an attached listener
      header.dataset.listenerAttached = 'true';
    });
  }

  // --- Astro View Transitions Handling ---
  
  // 1. Run immediately on initial load
  initializePlatformAccordion();
  
  // 2. Re-run after every View Transition navigation
  document.addEventListener('astro:page-load', initializePlatformAccordion);
</script>

</BaseLayout>
